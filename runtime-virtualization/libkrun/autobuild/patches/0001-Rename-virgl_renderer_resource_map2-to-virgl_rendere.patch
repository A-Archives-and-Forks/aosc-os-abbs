From 8bd35e0703591b9c3009f68af50b9e5202f01f8c Mon Sep 17 00:00:00 2001
From: Mikura Kyouka <13207280@qq.com>
Date: Thu, 4 Dec 2025 23:35:02 +0800
Subject: [PATCH] Rename `virgl_renderer_resource_map2` to
 `virgl_renderer_resource_map_fixed`

---
 Makefile                                                  | 4 ++--
 src/devices/Cargo.toml                                    | 2 +-
 src/devices/src/virtio/gpu/virtio_gpu.rs                  | 8 ++++----
 src/libkrun/Cargo.toml                                    | 2 +-
 src/rutabaga_gfx/Cargo.toml                               | 2 +-
 src/rutabaga_gfx/src/generated/virgl_renderer_bindings.rs | 4 ++--
 src/rutabaga_gfx/src/virgl_renderer.rs                    | 6 +++---
 7 files changed, 14 insertions(+), 14 deletions(-)

diff --git a/Makefile b/Makefile
index 8e07872..9a3f115 100644
--- a/Makefile
+++ b/Makefile
@@ -48,8 +48,8 @@ ifeq ($(TDX),1)
     INIT_SRC += $(KBS_INIT_SRC)
     BUILD_INIT = 0
 endif
-ifeq ($(VIRGL_RESOURCE_MAP2),1)
-	FEATURE_FLAGS += --features virgl_resource_map2
+ifeq ($(VIRGL_RESOURCE_MAP_FIXED),1)
+	FEATURE_FLAGS += --features virgl_resource_map_fixed
 endif
 ifeq ($(BLK),1)
     FEATURE_FLAGS += --features blk
diff --git a/src/devices/Cargo.toml b/src/devices/Cargo.toml
index b5024d7..8384da6 100644
--- a/src/devices/Cargo.toml
+++ b/src/devices/Cargo.toml
@@ -14,7 +14,7 @@ efi = ["blk", "net"]
 gpu = ["rutabaga_gfx", "thiserror", "zerocopy", "krun_display"]
 snd = ["pw", "thiserror"]
 input = ["zerocopy", "krun_input"]
-virgl_resource_map2 = []
+virgl_resource_map_fixed = []
 nitro = []
 test_utils = []
 
diff --git a/src/devices/src/virtio/gpu/virtio_gpu.rs b/src/devices/src/virtio/gpu/virtio_gpu.rs
index c383b6e..c228ba0 100644
--- a/src/devices/src/virtio/gpu/virtio_gpu.rs
+++ b/src/devices/src/virtio/gpu/virtio_gpu.rs
@@ -20,9 +20,9 @@ use krun_display::{
 use libc::c_void;
 #[cfg(target_os = "macos")]
 use rutabaga_gfx::RUTABAGA_MEM_HANDLE_TYPE_APPLE;
-#[cfg(all(not(feature = "virgl_resource_map2"), target_os = "linux"))]
+#[cfg(all(not(feature = "virgl_resource_map_fixed"), target_os = "linux"))]
 use rutabaga_gfx::RUTABAGA_MEM_HANDLE_TYPE_OPAQUE_FD;
-#[cfg(all(feature = "virgl_resource_map2", target_os = "linux"))]
+#[cfg(all(feature = "virgl_resource_map_fixed", target_os = "linux"))]
 use rutabaga_gfx::RUTABAGA_MEM_HANDLE_TYPE_SHM;
 use rutabaga_gfx::{
     ResourceCreate3D, ResourceCreateBlob, Rutabaga, RutabagaBuilder, RutabagaChannel,
@@ -702,7 +702,7 @@ impl VirtioGpu {
     /// rutabaga as ExternalMapping.
     /// When sandboxing is enabled, external_blob is set and opaque fds must be mapped in the
     /// hypervisor process by Vulkano using metadata provided by Rutabaga::vulkan_info().
-    #[cfg(all(not(feature = "virgl_resource_map2"), target_os = "linux"))]
+    #[cfg(all(not(feature = "virgl_resource_map_fixed"), target_os = "linux"))]
     pub fn resource_map_blob(
         &mut self,
         resource_id: u32,
@@ -759,7 +759,7 @@ impl VirtioGpu {
             map_info: map_info & RUTABAGA_MAP_CACHE_MASK,
         })
     }
-    #[cfg(all(feature = "virgl_resource_map2", target_os = "linux"))]
+    #[cfg(all(feature = "virgl_resource_map_fixed", target_os = "linux"))]
     pub fn resource_map_blob(
         &mut self,
         resource_id: u32,
diff --git a/src/libkrun/Cargo.toml b/src/libkrun/Cargo.toml
index cba7047..3f39195 100644
--- a/src/libkrun/Cargo.toml
+++ b/src/libkrun/Cargo.toml
@@ -15,7 +15,7 @@ efi = [ "blk", "net" ]
 gpu = ["krun_display"]
 snd = []
 input = ["krun_input", "vmm/input", "devices/input"]
-virgl_resource_map2 = []
+virgl_resource_map_fixed = []
 nitro = [ "dep:nitro", "dep:nitro-enclaves" ]
 
 [dependencies]
diff --git a/src/rutabaga_gfx/Cargo.toml b/src/rutabaga_gfx/Cargo.toml
index 6c8357b..ff571bd 100644
--- a/src/rutabaga_gfx/Cargo.toml
+++ b/src/rutabaga_gfx/Cargo.toml
@@ -12,7 +12,7 @@ gfxstream_stub = []
 gpu = []
 virgl_renderer = []
 virgl_renderer_next = []
-virgl_resource_map2 = []
+virgl_resource_map_fixed = []
 minigbm = []
 # To try out Vulkano, delete the following line and uncomment the line in "dependencies". Vulkano
 # features are just a prototype and not integrated yet into the ChromeOS build system.
diff --git a/src/rutabaga_gfx/src/generated/virgl_renderer_bindings.rs b/src/rutabaga_gfx/src/generated/virgl_renderer_bindings.rs
index 970e500..5fc70a5 100644
--- a/src/rutabaga_gfx/src/generated/virgl_renderer_bindings.rs
+++ b/src/rutabaga_gfx/src/generated/virgl_renderer_bindings.rs
@@ -378,9 +378,9 @@ extern "C" {
         out_size: *mut u64,
     ) -> ::std::os::raw::c_int;
 }
-#[cfg(feature = "virgl_resource_map2")]
+#[cfg(feature = "virgl_resource_map_fixed")]
 extern "C" {
-    pub fn virgl_renderer_resource_map2(
+    pub fn virgl_renderer_resource_map_fixed(
         res_handle: u32,
         map: *const ::std::os::raw::c_void,
         size: u64,
diff --git a/src/rutabaga_gfx/src/virgl_renderer.rs b/src/rutabaga_gfx/src/virgl_renderer.rs
index bbb3128..6915dff 100644
--- a/src/rutabaga_gfx/src/virgl_renderer.rs
+++ b/src/rutabaga_gfx/src/virgl_renderer.rs
@@ -699,10 +699,10 @@ impl RutabagaComponent for VirglRenderer {
         _prot: i32,
         _flags: i32,
     ) -> RutabagaResult<()> {
-        #[cfg(feature = "virgl_resource_map2")]
+        #[cfg(feature = "virgl_resource_map_fixed")]
         {
             let ret = unsafe {
-                virgl_renderer_resource_map2(
+                virgl_renderer_resource_map_fixed(
                     _resource_id,
                     _addr as *mut libc::c_void,
                     _size,
@@ -716,7 +716,7 @@ impl RutabagaComponent for VirglRenderer {
 
             Ok(())
         }
-        #[cfg(not(feature = "virgl_resource_map2"))]
+        #[cfg(not(feature = "virgl_resource_map_fixed"))]
         Err(RutabagaError::Unsupported)
     }
 
-- 
2.52.0

