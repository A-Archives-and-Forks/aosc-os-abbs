From 6ea3e31389fd98da2725e92bf3fb90857ab12da9 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Tue, 13 May 2025 13:46:27 +0800
Subject: [PATCH 2/5] FEDORA: fix(modules): initialise variables

Signed-off-by: Tom Callaway <spot@fedoraproject.org>

Link: https://src.fedoraproject.org/rpms/libmcrypt/blob/e597cfd07acb3d70421a63fc59d07d9423f8cff3/f/libmcrypt-2.5.8-uninitialized.patch
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 modules/algorithms/twofish.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/modules/algorithms/twofish.c b/modules/algorithms/twofish.c
index 2483838..003086f 100644
--- a/modules/algorithms/twofish.c
+++ b/modules/algorithms/twofish.c
@@ -499,7 +499,7 @@ static void f_rnd(int i, word32* blk, TWI* pkey, word32 t0, word32 t1)
 /* encrypt a block of text  */
 WIN32DLL_DEFINE void _mcrypt_encrypt(TWI * pkey, word32 * in_blk)
 {
-	word32 t0, t1, blk[4];
+	word32 t0 = 0, t1 = 0, blk[4];
 #ifdef WORDS_BIGENDIAN
 	blk[0] = byteswap32(in_blk[0]) ^ pkey->l_key[0];
 	blk[1] = byteswap32(in_blk[1]) ^ pkey->l_key[1];
-- 
