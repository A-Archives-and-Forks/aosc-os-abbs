From fb33fd33238c4898101917f0d9ee84c74bda5aad Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Tue, 13 May 2025 13:57:09 +0800
Subject: [PATCH 5/5] FEDORA: fix(configure): additional C compatibility fixes
 for GCC >= 14

From the original patch header:

  Fix glitches in the readdir and bcopy probes.  They were
  just invalid.

Signed-off-by: Florian Weimer <fweimer@redhat.com>

Link: https://src.fedoraproject.org/rpms/libmcrypt/blob/e02fbd614a5b7ba093e9e15ab322e7eb02d64e3b/f/libmcrypt-configure-c99-2.patch
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 configure    | 4 ++--
 configure.in | 4 ++--
 2 files changed, 4 insertions(+), 4 deletions(-)

diff --git a/configure b/configure
index 88cad19..7e1bfd2 100755
--- a/configure
+++ b/configure
@@ -6639,7 +6639,7 @@ fi
 done
 
 
-for ac_func in readdir,,
+for ac_func in readdir
 do
 as_ac_var=`echo "ac_cv_func_$ac_func" | $as_tr_sh`
 echo "$as_me:$LINENO: checking for $ac_func" >&5
@@ -6741,7 +6741,7 @@ fi
 done
 
 
-for ac_func in bcopy,,
+for ac_func in bcopy
 do
 as_ac_var=`echo "ac_cv_func_$ac_func" | $as_tr_sh`
 echo "$as_me:$LINENO: checking for $ac_func" >&5
diff --git a/configure.in b/configure.in
index a815778..f0c9a0e 100644
--- a/configure.in
+++ b/configure.in
@@ -204,8 +204,8 @@ AC_FUNC_MEMCMP
 AC_FUNC_REALLOC
 
 AC_CHECK_FUNCS([bzero memmove memset mlock readdir_r strchr strdup strrchr])
-AC_CHECK_FUNCS([readdir,,])
-AC_CHECK_FUNCS([bcopy,,])
+AC_CHECK_FUNCS([readdir])
+AC_CHECK_FUNCS([bcopy])
 
 dnl Checks for libraries.
 AC_C_BIGENDIAN
-- 
2.49.0

