From ec62637cabee5c2f3396143370f0b50e82ffad76 Mon Sep 17 00:00:00 2001
From: CAB233 <yidaduizuoye@outlook.com>
Date: Sun, 21 Sep 2025 09:38:16 +0800
Subject: [PATCH] adjust executable file path and name

---
 data/com.ubuntu.pkexec.synaptic.policy.in | 2 +-
 data/synaptic.desktop.in                  | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/data/com.ubuntu.pkexec.synaptic.policy.in b/data/com.ubuntu.pkexec.synaptic.policy.in
index 0df98406..93f645f3 100644
--- a/data/com.ubuntu.pkexec.synaptic.policy.in
+++ b/data/com.ubuntu.pkexec.synaptic.policy.in
@@ -12,7 +12,7 @@
       <allow_inactive>auth_admin</allow_inactive>
       <allow_active>auth_admin</allow_active>
     </defaults>
-    <annotate key="org.freedesktop.policykit.exec.path">/usr/sbin/synaptic</annotate>
+    <annotate key="org.freedesktop.policykit.exec.path">/usr/bin/synaptic</annotate>
     <annotate key="org.freedesktop.policykit.exec.allow_gui">true</annotate>
   </action>
 
diff --git a/data/synaptic.desktop.in b/data/synaptic.desktop.in
index 28025a86..6c5ee22d 100644
--- a/data/synaptic.desktop.in
+++ b/data/synaptic.desktop.in
@@ -2,7 +2,7 @@
 _Name=Synaptic Package Manager
 _GenericName=Package Manager
 _Comment=Install, remove and upgrade software packages
-Exec=synaptic-pkexec
+Exec=synaptic
 Icon=synaptic
 Terminal=false
 Type=Application
-- 
2.51.0

