abinfo "Configuring dinit ..."
"$SRCDIR"/configure \
	--prefix=/usr \
	--sbindir=/usr/bin \
	--shutdown-prefix='dinit-' \
	--disable-strip \
	--enable-cgroups \
	--enable-shutdown \
	--enable-capabilities \
	--enable-ioprio \
	--enable-oom-adj \
	--enable-utmpx \
	--enable-initgroups

abinfo "Building dinit ..."
make -C "$SRCDIR" all

abinfo "Installing dinit ..."
make -C "$SRCDIR" install DESTDIR="$PKGDIR"
