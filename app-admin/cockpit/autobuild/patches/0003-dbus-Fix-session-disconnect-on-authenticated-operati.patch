From d3a2f759998cc0782bc088890d4e6173f54889e6 Mon Sep 17 00:00:00 2001
From: darkyzhou <me@zqy.io>
Date: Sun, 16 Nov 2025 12:05:14 +0800
Subject: [PATCH 3/3] dbus: Fix session disconnect on authenticated operations

The original code only caught EBUSY when calling attach_event(), but
sd_bus_attach_event() can also return EINVAL in certain cases (e.g.,
when reusing singleton bus instances across different sessions). This
caused channel failures and session disconnects.

Catch both EBUSY and EINVAL during attach_event(), as both indicate
the bus is usable. Also add exception handling in get_ready() to
gracefully close channels when D-Bus setup fails, preventing "Task
exception was never retrieved" errors.
---
 src/cockpit/channels/dbus.py | 20 +++++++++++++-------
 1 file changed, 13 insertions(+), 7 deletions(-)

diff --git a/src/cockpit/channels/dbus.py b/src/cockpit/channels/dbus.py
index 9bde238b6..0290725d7 100644
--- a/src/cockpit/channels/dbus.py
+++ b/src/cockpit/channels/dbus.py
@@ -247,7 +247,7 @@ class DBusChannel(Channel):
         try:
             self.bus.attach_event(None, 0)
         except OSError as err:
-            if err.errno != errno.EBUSY:
+            if err.errno not in (errno.EBUSY, errno.EINVAL):
                 raise
 
         # This needs to be a fair mutex so that outgoing messages don't
@@ -256,12 +256,18 @@ class DBusChannel(Channel):
 
         if self.name is not None:
             async def get_ready() -> None:
-                async with self.watch_processing_lock:
-                    await self.setup_name_owner_tracking()
-                    if self.owner:
-                        self.ready(unique_name=self.owner)
-                    else:
-                        self.close({'problem': 'not-found'})
+                try:
+                    async with self.watch_processing_lock:
+                        await self.setup_name_owner_tracking()
+                        if self.owner:
+                            self.ready(unique_name=self.owner)
+                        else:
+                            self.close({'problem': 'not-found'})
+                except Exception as exc:
+                    # If setup fails (e.g., due to timing issues with bus state),
+                    # close the channel gracefully instead of leaving the task hanging
+                    logger.debug('Failed to setup D-Bus channel for %s: %s', self.name, exc)
+                    self.close({'problem': 'protocol-error', 'message': str(exc)})
             self.create_task(get_ready())
         else:
             self.ready()
