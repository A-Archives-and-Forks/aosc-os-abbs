abinfo "Installing pam file ..."
install -Dvm644 "$SRCDIR"/tools/arch/cockpit.pam \
		"$PKGDIR"/etc/pam.d/cockpit.pam

abinfo "Removing kdump and selinux module ..."
rm -rv "$PKGDIR"/usr/share/cockpit/{kdump,selinux}
rm -v "$PKGDIR"/usr/share/metainfo/org.cockpit_project.cockpit_{kdump,selinux}.metainfo.xml

abinfo "Removing unwanted bundled fonts ..."
rm -rv "$PKGDIR"/usr/share/cockpit/static/fonts
