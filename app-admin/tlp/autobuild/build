# do not install tlp.init
export TLP_NO_INIT=1

# Install directory
export TLP_SBIN=/usr/bin

# Install directory for systemd units
export TLP_SYSD=/usr/lib/systemd/system

# Install directory for systemd suspend/resume hooks
export TLP_SDSL=/usr/lib/systemd/system-sleep

# Install directory for udev scripts
export TLP_ULIB=/usr/lib/udev

# do not install elogind script
export TLP_WITH_ELOGIND=0

# install systemd unit files
export TLP_WITH_SYSTEMD=1

make DESTDIR="$PKGDIR" \
    install-tlp install-man install-rdw install-man-rdw install-pd install-man-pd
