PKGNAME=colord
PKGSEC=admin
PKGDEP="argyllcms dconf dbus lcms2 libgudev libgusb \
        polkit sqlite systemd"
BUILDDEP="bash-completion docbook-utils gobject-introspection \
          intltool vala sane-backends"
BUILDDEP__RETRO="bash-completion docbook-utils docbook-xsl sane-backends"
PKGDES="System daemon for managing color devices"

MESON_AFTER=(
	'-Ddaemon=true'
	'-Dsession_example=false'
	'-Dbash_completion=true'
	'-Dudev_rules=true'
	'-Dsystemd=true'
	'-Dlibcolordcompat=true'
	'-Dargyllcms_sensor=true'
	'-Dsane=true'
	'-Dintrospection=true'
	'-Dvapi=true'
	'-Dprint_profiles=true'
	'-Dinstalled_tests=false'
	'-Ddaemon_user=colord'
	'-Dpnp_ids=/usr/share/hwdata/pnp.ids'
	'-Dman=true'
	'-Ddocs=false'
)

MESON_AFTER__RETRO=(
	"${MESON_AFTER[@]}"
	'-Dintrospection=false'
	'-Dvapi=false'
)
