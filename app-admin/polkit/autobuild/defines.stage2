PKGNAME=polkit
PKGDES="Application development toolkit for controlling system-wide privileges"
PKGSEC=admin
PKGDEP="expat glib linux-pam duktape systemd"
BUILDDEP="autoconf-archive gobject-introspection"

ABTYPE=meson
MESON_AFTER=(
    "-Dsession_tracking=logind"
    "-Dgtk_doc=false"
    "-Dintrospection=false"
)

PKGEPOCH=1
