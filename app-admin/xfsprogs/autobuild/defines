PKGNAME=xfsprogs
PKGSEC=utils
PKGDEP="icu inih liburcu util-linux"
PKGDES="XFS filesystem utilities"

ABSHADOW=0
RECONF=0
NOPARALLEL=1

ABTYPE=autotools
AUTOTOOLS_AFTER=(
    "--enable-shared"
    "--enable-gettext"
    "--enable-editline"
    "--disable-termcap"
    "--enable-lib64"
    "--enable-librt"
    "--disable-ubsan"
    "--disable-addrsan"
    "--disable-threadsan"
    "--enable-lto"
    "--enable-scrub"
    "--enable-libicu"
)
