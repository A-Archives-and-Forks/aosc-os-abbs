From 35f2407f820dcb011c71c4c8de2b5372272684c6 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Tue, 2 Dec 2025 19:55:13 +0800
Subject: [PATCH 419/419] AOSCOS: can: loongson_can: limit to LOONGARCH

This is only found on Loongson SoCs.

Fixes: "LOONGSON: can: loongson_can: Add Loongson-2K3000 CANFD controller support"
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 drivers/net/can/loongson_canfd/Kconfig | 1 +
 1 file changed, 1 insertion(+)

diff --git a/drivers/net/can/loongson_canfd/Kconfig b/drivers/net/can/loongson_canfd/Kconfig
index 518de120330e..9732a6c45fc3 100644
--- a/drivers/net/can/loongson_canfd/Kconfig
+++ b/drivers/net/can/loongson_canfd/Kconfig
@@ -1,6 +1,7 @@
 menuconfig CAN_LSCANFD
 	tristate "Support LSCAN devices"
 	depends on HAS_IOMEM
+	depends on LOONGARCH || COMPILE_TEST
 
 if CAN_LSCANFD
 
