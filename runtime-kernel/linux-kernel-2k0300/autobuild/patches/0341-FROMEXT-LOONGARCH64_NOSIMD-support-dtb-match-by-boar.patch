From 6043e8858d2103807e5763ba11360a64892794ea Mon Sep 17 00:00:00 2001
From: Ilikara <3435193369@qq.com>
Date: Sun, 16 Nov 2025 13:56:53 +0800
Subject: [PATCH 341/507] FROMEXT: LOONGARCH64_NOSIMD: support dtb match by
 board_name from cmdline

Link: https://gitee.com/open-loongarch/linux-6.12/commit/7ffd18ab9d2bd5cc64dda6b33e8fac58edfe9279

Signed-off-by: Ilikara <3435193369@qq.com>
---
 arch/loongarch/Kconfig        | 13 +++++++++++-
 arch/loongarch/kernel/setup.c | 40 ++++++++++++++++++++++++++++++++++-
 2 files changed, 51 insertions(+), 2 deletions(-)

diff --git a/arch/loongarch/Kconfig b/arch/loongarch/Kconfig
index e7540e6e3aa9..6f351a2be28e 100644
--- a/arch/loongarch/Kconfig
+++ b/arch/loongarch/Kconfig
@@ -541,9 +541,20 @@ config BUILTIN_DTB
 
 	  Built-in DTBs are generic enough and can be used as references.
 
+config DTB_MATCH_BY_BOARD_NAME
+	bool "dtb match by board_name which from command line"
+	depends on BUILTIN_DTB
+	default y
+	help
+	  Base name (without suffix, relative to arch/loongarch/boot/dts/)
+	  for the DTS file that will be used to produce the DTB linked into
+	  the kernel.
+	  support match dtb by board_name which from command line
+	  so that bootloader given this value in command line
+
 config BUILTIN_DTB_NAME
 	string "Source file for built-in dtb"
-	depends on BUILTIN_DTB
+	depends on BUILTIN_DTB && !DTB_MATCH_BY_BOARD_NAME
 	help
 	  Base name (without suffix, relative to arch/loongarch/boot/dts/)
 	  for the DTS file that will be used to produce the DTB linked into
diff --git a/arch/loongarch/kernel/setup.c b/arch/loongarch/kernel/setup.c
index 61f00ff77f9e..9d740a7ac410 100644
--- a/arch/loongarch/kernel/setup.c
+++ b/arch/loongarch/kernel/setup.c
@@ -50,6 +50,11 @@
 #include <asm/unwind.h>
 
 #include "legacy_boot.h"
+#include <boot_param.h>
+
+#ifndef CONFIG_BUILTIN_DTB_NAME
+#define CONFIG_BUILTIN_DTB_NAME ""
+#endif
 
 #define SMBIOS_BIOSSIZE_OFFSET		0x09
 #define SMBIOS_BIOSEXTERN_OFFSET	0x13
@@ -75,6 +80,7 @@ static const char dmi_empty_string[] = "        ";
  * These are initialized so they are in the .data section
  */
 char init_command_line[COMMAND_LINE_SIZE] __initdata;
+char board_name_desc[] = "board_name="; // 这是 command line 里面的内容 一定要有=
 
 static int num_standard_resources;
 static struct resource *standard_resources;
@@ -276,6 +282,30 @@ static void __init arch_reserve_crashkernel(void)
 	reserve_crashkernel_generic(cmdline, crash_size, crash_base, low_size, high);
 }
 
+#ifdef CONFIG_DTB_MATCH_BY_BOARD_NAME
+static void* __init get_fdt_by_board_name(void)
+{
+	void *fdt = NULL;
+	char* board_name;
+	char temp[128]; // 不想申请空间 应该不会有这么长的名字吧
+	board_name = strstr(boot_command_line, board_name_desc);
+	if (board_name) {
+		int i;
+		memset(temp, 0, 128);
+		board_name += strlen(board_name_desc); // 跳过 = 和前面的字段
+		for (i = 0; i < 127; ++i) {
+			if (board_name[i] == 0 || board_name[i] == ' ')
+				break;
+			temp[i] = board_name[i];
+		}
+		board_name = temp;
+	}
+	if (board_name) {
+	}
+	return fdt;
+}
+#endif
+
 static void __init fdt_setup(void)
 {
 #ifdef CONFIG_OF_EARLY_FLATTREE
@@ -285,11 +315,19 @@ static void __init fdt_setup(void)
 	if (acpi_os_get_root_pointer())
 		return;
 
+	fdt_pointer = NULL;
+
+#ifdef CONFIG_DTB_MATCH_BY_BOARD_NAME
+	fdt_pointer = efi_fdt_pointer(); /* Fallback to firmware dtb */
+	if (!fdt_pointer)
+		fdt_pointer = get_fdt_by_board_name();
+#else
 	/* Prefer to use built-in dtb, checking its legality first. */
-	if (IS_ENABLED(CONFIG_BUILTIN_DTB) && !fdt_check_header(__dtb_start))
+	if (!fdt_check_header(__dtb_start) && strcmp(CONFIG_BUILTIN_DTB_NAME, ""))
 		fdt_pointer = __dtb_start;
 	else
 		fdt_pointer = efi_fdt_pointer(); /* Fallback to firmware dtb */
+#endif
 
 	if (!fdt_pointer || fdt_check_header(fdt_pointer))
 		return;
-- 
2.52.0

