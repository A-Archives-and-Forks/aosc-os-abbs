+			clock-frequency = <72200000>;
+			hactive = <1280>;
+			vactive = <800>;
+			hsync-len = <4>;
+			hfront-porch = <72>;
+			hback-porch = <84>;
+			vfront-porch = <15>;
+			vback-porch = <23>;
+			vsync-len = <4>;
+			de-active = <1>;
+			hsync-active = <0>;
+			vsync-active = <0>;
+			pixelclk-active = <0>;
+		};
+
+		port@0 {
+			reg = <0>;
+
+			#address-cells = <1>;
+			#size-cells = <0>;
+
+			dvo_connector_in: endpoint@0 {
+				reg = <0>;
+				remote-endpoint = <&dc_out_rgb0>;
+			};
+		};
+	};
+
+	vccio_codec: 3_3V{
+		compatible = "regulator-fixed";
+		regulator-name = "VCC_IO";
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+		regulator-always-on;
+	};
+
+	// 虽然这个时钟在从模式下没用，但 es8388 驱动必须指定这个时钟
