From 281c837fb5590741ae4d74d71d19333b2ee5a74c Mon Sep 17 00:00:00 2001
From: maoxiaochuan <maoxiaochuan@loongson.cn>
Date: Wed, 20 Aug 2025 08:31:54 +0800
Subject: [PATCH 461/507] Revert "irqchip/loongson-pch-msi.c: Switch to
 msi_create_parent_irq_domain()"

This reverts commit fbcfa60948dfdca3c01ec64b6ac6b101e2111268.
---
 drivers/irqchip/irq-loongson-pch-msi.c | 25 +++++++++++++++----------
 1 file changed, 15 insertions(+), 10 deletions(-)

diff --git a/drivers/irqchip/irq-loongson-pch-msi.c b/drivers/irqchip/irq-loongson-pch-msi.c
index ab473e1b0582..bd337ecddb40 100644
--- a/drivers/irqchip/irq-loongson-pch-msi.c
+++ b/drivers/irqchip/irq-loongson-pch-msi.c
@@ -152,21 +152,26 @@ static struct msi_parent_ops pch_msi_parent_ops = {
 	.init_dev_msi_info	= msi_lib_init_dev_msi_info,
 };
 
-static int pch_msi_init_domains(struct pch_msi_data *priv, struct irq_domain *parent,
+static int pch_msi_init_domains(struct pch_msi_data *priv,
+				struct irq_domain *parent,
 				struct fwnode_handle *domain_handle)
 {
-	struct irq_domain_info info = {
-		.ops		= &pch_msi_middle_domain_ops,
-		.size		= priv->num_irqs,
-		.parent		= parent,
-		.host_data	= priv,
-		.fwnode		= domain_handle,
-	};
-
-	if (!msi_create_parent_irq_domain(&info, &pch_msi_parent_ops)) {
+	struct irq_domain *middle_domain;
+
+	middle_domain = irq_domain_create_hierarchy(parent, 0, priv->num_irqs,
+						    domain_handle,
+						    &pch_msi_middle_domain_ops,
+						    priv);
+	if (!middle_domain) {
 		pr_err("Failed to create the MSI middle domain\n");
 		return -ENOMEM;
 	}
+
+	irq_domain_update_bus_token(middle_domain, DOMAIN_BUS_NEXUS);
+
+	middle_domain->flags |= IRQ_DOMAIN_FLAG_MSI_PARENT;
+	middle_domain->msi_parent_ops = &pch_msi_parent_ops;
+
 	return 0;
 }
 
-- 
