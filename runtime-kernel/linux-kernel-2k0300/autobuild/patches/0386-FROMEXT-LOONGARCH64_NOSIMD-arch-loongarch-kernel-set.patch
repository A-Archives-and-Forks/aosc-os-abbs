+				fdt = fdts[i];
+				is_found = true;
+				// pr_info("======>board_name:%s i:%lu\n", board_name, i);
+				break;
+			}
+		}
+
+		if (!is_found) {
+			fdt = board_names[0];
 		}
-#elif defined(CONFIG_LOONGSON_2P500)
-		if (!strncmp(board_name, "LS2P500-GBKPJM0", 15))
