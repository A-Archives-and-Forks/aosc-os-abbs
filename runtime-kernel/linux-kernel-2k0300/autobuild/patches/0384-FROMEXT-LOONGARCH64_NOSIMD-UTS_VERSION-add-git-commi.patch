From f31e6d2310d062b4e68584edd52ff9f4a12a4c8d Mon Sep 17 00:00:00 2001
From: Ilikara <3435193369@qq.com>
Date: Mon, 24 Nov 2025 20:20:35 +0800
Subject: [PATCH 384/507] FROMEXT: LOONGARCH64_NOSIMD: UTS_VERSION add git
 commit id

Signed-off-by: maoxiaochuan <maoxiaochuan@loongson.cn>

Link: https://gitee.com/open-loongarch/linux-6.12/commit/99f01b458edb98332e8137d311228d6d05ec10de

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>

Signed-off-by: Ilikara <3435193369@qq.com>
---
 init/Makefile | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/init/Makefile b/init/Makefile
index 10b652d33e87..d1f88b56e39c 100644
--- a/init/Makefile
+++ b/init/Makefile
@@ -27,13 +27,14 @@ smp-flag-$(CONFIG_SMP)			:= SMP
 preempt-flag-$(CONFIG_PREEMPT_BUILD)	:= PREEMPT
 preempt-flag-$(CONFIG_PREEMPT_DYNAMIC)	:= PREEMPT_DYNAMIC
 preempt-flag-$(CONFIG_PREEMPT_RT)	:= PREEMPT_RT
+kernel-git-info 			:= $(shell git rev-parse --short HEAD || echo "unknown-ver")
 
 build-version = $(or $(KBUILD_BUILD_VERSION), $(build-version-auto))
 build-timestamp = $(or $(KBUILD_BUILD_TIMESTAMP), $(build-timestamp-auto))
 
 # Maximum length of UTS_VERSION is 64 chars
 filechk_uts_version = \
-	utsver=$$(echo '$(pound)'"$(build-version)" $(smp-flag-y) $(preempt-flag-y) "$(build-timestamp)" | cut -b -64); \
+	utsver=$$(echo '$(pound)'"$(build-version)" $(smp-flag-y) $(preempt-flag-y) $(kernel-git-info) "$(build-timestamp)" | cut -b -64); \
 	echo '$(pound)'define UTS_VERSION \""$${utsver}"\"
 
 #
