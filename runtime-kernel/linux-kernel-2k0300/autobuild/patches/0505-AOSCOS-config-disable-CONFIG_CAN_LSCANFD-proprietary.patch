From 2d37257419646c641730ff137978b71e7b4edc60 Mon Sep 17 00:00:00 2001
From: Ilikara <3435193369@qq.com>
Date: Mon, 7 Jul 2025 15:34:41 +0800
Subject: [PATCH 505/507] AOSCOS: config: disable CONFIG_CAN_LSCANFD
 (proprietary driver)

Signed-off-by: Ilikara <3435193369@qq.com>
---
 arch/loongarch/configs/loongson_2k300_defconfig    | 2 --
 arch/loongarch/configs/loongson_2k300_rt_defconfig | 2 --
 2 files changed, 4 deletions(-)

diff --git a/arch/loongarch/configs/loongson_2k300_defconfig b/arch/loongarch/configs/loongson_2k300_defconfig
index 1e4c3f511b44..c9704cab8edd 100644
--- a/arch/loongarch/configs/loongson_2k300_defconfig
+++ b/arch/loongarch/configs/loongson_2k300_defconfig
@@ -445,8 +445,6 @@ CONFIG_STMMAC_ETH=y
 # CONFIG_NET_VENDOR_XILINX is not set
 CONFIG_MOTORCOMM_PHY=y
 CONFIG_REALTEK_PHY=m
-CONFIG_CAN_LSCANFD=y
-CONFIG_CAN_LSCANFD_PLATFORM=y
 CONFIG_PPP=m
 CONFIG_PPP_BSDCOMP=m
 CONFIG_PPP_DEFLATE=m
diff --git a/arch/loongarch/configs/loongson_2k300_rt_defconfig b/arch/loongarch/configs/loongson_2k300_rt_defconfig
index 962d5b7697cd..f78c79d2f455 100644
--- a/arch/loongarch/configs/loongson_2k300_rt_defconfig
+++ b/arch/loongarch/configs/loongson_2k300_rt_defconfig
@@ -446,8 +446,6 @@ CONFIG_STMMAC_ETH=y
 # CONFIG_NET_VENDOR_XILINX is not set
 CONFIG_MOTORCOMM_PHY=y
 CONFIG_REALTEK_PHY=m
-CONFIG_CAN_LSCANFD=y
-CONFIG_CAN_LSCANFD_PLATFORM=y
 CONFIG_PPP=m
 CONFIG_PPP_BSDCOMP=m
 CONFIG_PPP_DEFLATE=m
