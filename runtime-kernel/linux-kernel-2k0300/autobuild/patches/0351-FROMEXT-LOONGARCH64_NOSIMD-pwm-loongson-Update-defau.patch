From 663943f455f01a0ee0ad3b2a7742f0f2ccfe7b66 Mon Sep 17 00:00:00 2001
From: Ilikara <3435193369@qq.com>
Date: Sun, 16 Nov 2025 14:19:32 +0800
Subject: [PATCH 351/507] FROMEXT: LOONGARCH64_NOSIMD: pwm: loongson: Update
 default frequency and improve DTS/idle-level behavior
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

11. pwm: update default pwm freq to 50Mhz
12. loongson pwm 驱动支持dts使用clock-frequency形式声明频率
13. loongson pwm 确保disable时输出的电平为空闲电平

Signed-off-by: maoxiaochuan <maoxiaochuan@loongson.cn>

Link: https://gitee.com/open-loongarch/linux-6.12/commit/7ffd18ab9d2bd5cc64dda6b33e8fac58edfe9279

Signed-off-by: Ilikara <3435193369@qq.com>
---
 drivers/pwm/Kconfig        |  9 +++++++++
 drivers/pwm/Makefile       |  1 +
 drivers/pwm/pwm-loongson.c | 40 ++++++++++++++++++++++++++++++++------
 3 files changed, 44 insertions(+), 6 deletions(-)

diff --git a/drivers/pwm/Kconfig b/drivers/pwm/Kconfig
index ef02a44d83a7..0238ab9b8796 100644
--- a/drivers/pwm/Kconfig
+++ b/drivers/pwm/Kconfig
@@ -757,4 +757,13 @@ config PWM_XILINX
 	  To compile this driver as a module, choose M here: the module
 	  will be called pwm-xilinx.
 
+config PWM_LS
+	tristate "Loongson PWM support"
+	depends on LOONGSON_2K500 || LOONGSON_2K1000 || LOONGSON_2K300 || LOONGSON_2P500
+	help
+	  Generic PWM framework driver for loongson3.
+
+	  To compile this driver as a module, choose M here: the module
+	  will be called pwm-ls.
+
 endif
diff --git a/drivers/pwm/Makefile b/drivers/pwm/Makefile
index 7c18c9be419f..feb1ab5930d1 100644
--- a/drivers/pwm/Makefile
+++ b/drivers/pwm/Makefile
@@ -70,3 +70,4 @@ obj-$(CONFIG_PWM_TWL_LED)	+= pwm-twl-led.o
 obj-$(CONFIG_PWM_VISCONTI)	+= pwm-visconti.o
 obj-$(CONFIG_PWM_VT8500)	+= pwm-vt8500.o
 obj-$(CONFIG_PWM_XILINX)	+= pwm-xilinx.o
+obj-$(CONFIG_PWM_LS)		+= pwm-ls.o
diff --git a/drivers/pwm/pwm-loongson.c b/drivers/pwm/pwm-loongson.c
index e34a450e3838..453eea15d8c4 100644
--- a/drivers/pwm/pwm-loongson.c
+++ b/drivers/pwm/pwm-loongson.c
@@ -27,6 +27,7 @@
 #include <linux/platform_device.h>
 #include <linux/pwm.h>
 #include <linux/units.h>
+#include <linux/delay.h>
 
 /* Loongson PWM registers */
 #define LOONGSON_PWM_REG_DUTY		0x4 /* Low Pulse Buffer Register */
@@ -45,7 +46,7 @@
 #define LOONGSON_PWM_CTRL_DZONE		BIT(10) /* Anti-dead Zone Enable Bit */
 
 /* default input clk frequency for the ACPI case */
-#define LOONGSON_PWM_FREQ_DEFAULT	50000 /* Hz */
+#define LOONGSON_PWM_FREQ_DEFAULT	50000000 /* Hz */
 
 struct pwm_loongson_ddata {
 	struct clk *clk;
@@ -79,10 +80,10 @@ static int pwm_loongson_set_polarity(struct pwm_chip *chip, struct pwm_device *p
 
 	if (polarity == PWM_POLARITY_INVERSED)
 		/* Duty cycle defines LOW period of PWM */
-		val |= LOONGSON_PWM_CTRL_INVERT;
+		val &= ~LOONGSON_PWM_CTRL_INVERT;
 	else
 		/* Duty cycle defines HIGH period of PWM */
-		val &= ~LOONGSON_PWM_CTRL_INVERT;
+		val |= LOONGSON_PWM_CTRL_INVERT;
 
 	pwm_loongson_writel(ddata, val, LOONGSON_PWM_REG_CTRL);
 
@@ -92,11 +93,31 @@ static int pwm_loongson_set_polarity(struct pwm_chip *chip, struct pwm_device *p
 static void pwm_loongson_disable(struct pwm_chip *chip, struct pwm_device *pwm)
 {
 	u32 val;
+	u32 duty;
+	u32 period;
+	u32 period_1000ns;
 	struct pwm_loongson_ddata *ddata = to_pwm_loongson_ddata(chip);
 
+	duty = pwm_loongson_readl(ddata, LOONGSON_PWM_REG_DUTY);
+	period = pwm_loongson_readl(ddata, LOONGSON_PWM_REG_PERIOD);
+
+	period_1000ns = mul_u64_u64_div_u64(1000, ddata->clk_rate, NSEC_PER_SEC);
+	pwm_loongson_writel(ddata, 1, LOONGSON_PWM_REG_DUTY);
+	pwm_loongson_writel(ddata, period_1000ns, LOONGSON_PWM_REG_PERIOD);
+	val = pwm_loongson_readl(ddata, LOONGSON_PWM_REG_CTRL);
+	val |= LOONGSON_PWM_CTRL_RST;
+	pwm_loongson_writel(ddata, val, LOONGSON_PWM_REG_CTRL);
+	val ^= LOONGSON_PWM_CTRL_RST;
+	pwm_loongson_writel(ddata, val, LOONGSON_PWM_REG_CTRL);
+
+	ndelay(1000);
+
 	val = pwm_loongson_readl(ddata, LOONGSON_PWM_REG_CTRL);
 	val &= ~LOONGSON_PWM_CTRL_EN;
 	pwm_loongson_writel(ddata, val, LOONGSON_PWM_REG_CTRL);
+
+	pwm_loongson_writel(ddata, duty, LOONGSON_PWM_REG_DUTY);
+	pwm_loongson_writel(ddata, period, LOONGSON_PWM_REG_PERIOD);
 }
 
 static int pwm_loongson_enable(struct pwm_chip *chip, struct pwm_device *pwm)
@@ -171,8 +192,8 @@ static int pwm_loongson_get_state(struct pwm_chip *chip, struct pwm_device *pwm,
 	/* duty & period have a max of 2^32, so we can't overflow */
 	state->duty_cycle = DIV64_U64_ROUND_UP((u64)duty * NSEC_PER_SEC, ddata->clk_rate);
 	state->period = DIV64_U64_ROUND_UP((u64)period * NSEC_PER_SEC, ddata->clk_rate);
-	state->polarity = (ctrl & LOONGSON_PWM_CTRL_INVERT) ? PWM_POLARITY_INVERSED :
-			  PWM_POLARITY_NORMAL;
+	state->polarity = (ctrl & LOONGSON_PWM_CTRL_INVERT) ? PWM_POLARITY_NORMAL :
+			  PWM_POLARITY_INVERSED;
 	state->enabled = (ctrl & LOONGSON_PWM_CTRL_EN) ? true : false;
 
 	return 0;
@@ -189,6 +210,8 @@ static int pwm_loongson_probe(struct platform_device *pdev)
 	struct pwm_chip *chip;
 	struct pwm_loongson_ddata *ddata;
 	struct device *dev = &pdev->dev;
+	struct device_node *np = dev->of_node;
+	u32 of_clk_freq = 0;
 
 	chip = devm_pwmchip_alloc(dev, 1, sizeof(*ddata));
 	if (IS_ERR(chip))
@@ -203,6 +226,7 @@ static int pwm_loongson_probe(struct platform_device *pdev)
 	if (IS_ERR(ddata->clk))
 		return dev_err_probe(dev, PTR_ERR(ddata->clk),
 				     "Failed to get pwm clock\n");
+	ddata->clk_rate = LOONGSON_PWM_FREQ_DEFAULT;
 	if (ddata->clk) {
 		ret = devm_clk_rate_exclusive_get(dev, ddata->clk);
 		if (ret)
@@ -211,7 +235,10 @@ static int pwm_loongson_probe(struct platform_device *pdev)
 
 		ddata->clk_rate = clk_get_rate(ddata->clk);
 	} else {
-		ddata->clk_rate = LOONGSON_PWM_FREQ_DEFAULT;
+#ifdef CONFIG_OF
+		if (!of_property_read_u32(np, "clock-frequency", &of_clk_freq))
+			ddata->clk_rate = of_clk_freq;
+#endif
 	}
 
 	chip->ops = &pwm_loongson_ops;
@@ -252,6 +279,7 @@ static DEFINE_SIMPLE_DEV_PM_OPS(pwm_loongson_pm_ops, pwm_loongson_suspend,
 
 static const struct of_device_id pwm_loongson_of_ids[] = {
 	{ .compatible = "loongson,ls7a-pwm" },
+	{ .compatible = "loongson,ls2k-pwm" },
 	{ /* sentinel */ },
 };
 MODULE_DEVICE_TABLE(of, pwm_loongson_of_ids);
-- 
2.52.0

