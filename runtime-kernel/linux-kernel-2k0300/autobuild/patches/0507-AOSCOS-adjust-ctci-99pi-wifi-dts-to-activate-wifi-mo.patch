From 268ea006831c7208be79a5a8ef5d36b7a673cdfe Mon Sep 17 00:00:00 2001
From: ilikara <3435193369@qq.com>
Date: Mon, 15 Sep 2025 14:51:38 +0800
Subject: [PATCH 507/507] AOSCOS: adjust ctci 99pi-wifi dts to activate wifi
 module

Signed-off-by: ilikara <3435193369@qq.com>
---
 arch/loongarch/boot/dts/ls2k300_99pi.dtsi     |  1 -
 arch/loongarch/boot/dts/ls2k300_99pi_wifi.dts | 14 ++++++++++++++
 2 files changed, 14 insertions(+), 1 deletion(-)

diff --git a/arch/loongarch/boot/dts/ls2k300_99pi.dtsi b/arch/loongarch/boot/dts/ls2k300_99pi.dtsi
index fc4c73714e52..91574a74152f 100644
--- a/arch/loongarch/boot/dts/ls2k300_99pi.dtsi
+++ b/arch/loongarch/boot/dts/ls2k300_99pi.dtsi
@@ -179,6 +179,5 @@ &rtc0 {
 };
 
 &sdio1 {
-	cd-gpios = <&gpio 82 GPIO_ACTIVE_LOW>;
 	status = "okay";
 };
diff --git a/arch/loongarch/boot/dts/ls2k300_99pi_wifi.dts b/arch/loongarch/boot/dts/ls2k300_99pi_wifi.dts
index 4b1147fa6119..c9fe21f6b8ae 100644
--- a/arch/loongarch/boot/dts/ls2k300_99pi_wifi.dts
+++ b/arch/loongarch/boot/dts/ls2k300_99pi_wifi.dts
@@ -11,4 +11,18 @@
 
 / {
 	product = "LS2K300-99PI-WIFI";
+
+	sdio_pwrseq: sdio-pwrseq {
+		compatible = "mmc-pwrseq-simple";
+		pinctrl-names = "default";
+		pinctrl-0 = <&sdio0en>;
+		reset-gpios = <&gpio 81 GPIO_ACTIVE_HIGH>;
+	};
+
+};
+
+&pinmux {
+	sdio0en: pinmux_G81_as_sdio0en {
+		pinctrl-single,bits = <0x14 0x00000000 0x0000000c>;
+	};
 };
-- 
2.52.0

