From 83f5918aad57a313668d83673cbfd3311ebb27f8 Mon Sep 17 00:00:00 2001
From: pch666777 <1005100717@qq.com>
Date: Wed, 21 May 2025 19:49:12 +0800
Subject: [PATCH 1/2] cpp system process add mips64 cpu

---
 cpp/cmake_modules/SetupCxxFlags.cmake | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/cpp/cmake_modules/SetupCxxFlags.cmake b/cpp/cmake_modules/SetupCxxFlags.cmake
index 2211308de8..92de650c66 100644
--- a/cpp/cmake_modules/SetupCxxFlags.cmake
+++ b/cpp/cmake_modules/SetupCxxFlags.cmake
@@ -40,6 +40,8 @@ if(NOT DEFINED ARROW_CPU_FLAG)
     set(ARROW_CPU_FLAG "riscv64")
   elseif(CMAKE_SYSTEM_PROCESSOR MATCHES "loongarch64")
     set(ARROW_CPU_FLAG "loongarch64")
+  elseif(CMAKE_SYSTEM_PROCESSOR MATCHES "mips64")
+    set(ARROW_CPU_FLAG "mips64")
   else()
     message(FATAL_ERROR "Unknown system processor")
   endif()
