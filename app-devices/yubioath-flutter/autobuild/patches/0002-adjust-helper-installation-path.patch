 version = "0.1.0"
 description = "Yubico Authenticator Helper"
 authors = [{ name = "Dain Nilsson", email = "dain@yubico.com" }]
@@ -22,7 +22,7 @@ dev = [
 
 [tool.poetry]
 requires-poetry = ">=2.0"
-packages = [{ include = "helper" }]
+packages = [{ include = "yubioath_flutter_helper" }]
 
 [build-system]
 requires = ["poetry-core>=2.0"]
