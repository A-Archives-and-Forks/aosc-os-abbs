 helper/authenticator-helper.py | 2 +-
 helper/pyproject.toml          | 4 ++--
 2 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/helper/authenticator-helper.py b/helper/authenticator-helper.py
index 6a069800..e354fc36 100644
--- a/helper/authenticator-helper.py
+++ b/helper/authenticator-helper.py
@@ -19,7 +19,7 @@ import socket
