PKGNAME=switcheroo-control
PKGSEC=utils
PKGDEP="dbus gcc-runtime glib glibc libdrm libgudev pygobject-3"
BUILDDEP="dbus-python meson python-dbusmock systemd"
PKGDES="D-Bus service to check the availability of dual-GPU"

ABTYPE=meson
MESON_AFTER=(
    '-Dgtk_doc=false'
    '-Dtests=false'
    '-Dlibdrm=enabled'
    '-Dlibdrm_nouveau=enabled'
    '-Dlibdrm_amdgpu=enabled'
    '-Ddrm_xe=enabled'
)
