Date: Thu, 29 Jan 2026 23:16:48 +0800
Subject: [PATCH 1/3] AOSCOS: use local patched rusty_v8

---
 Cargo.lock | 2 --
 Cargo.toml | 3 +++
 2 files changed, 3 insertions(+), 2 deletions(-)

diff --git a/Cargo.lock b/Cargo.lock
index 693c399a0..0fb374932 100644
--- a/Cargo.lock
+++ b/Cargo.lock
@@ -10446,8 +10446,6 @@ dependencies = [
 [[package]]
 name = "v8"
 version = "145.0.0"
-source = "registry+https://github.com/rust-lang/crates.io-index"
-checksum = "61d9a107e16bae35a0be2bb0096ac1d2318aac352c82edd796ab2b9cac66d8f0"
 dependencies = [
  "bindgen 0.72.1",
  "bitflags 2.9.3",
diff --git a/Cargo.toml b/Cargo.toml
index 4fd99f146..074400d92 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -561,3 +561,6 @@ opt-level = 3
 opt-level = 3
 [profile.release.package.deno_npm_cache]
 opt-level = 3
+
+[patch.crates-io]
+v8 = { path = '../rusty_v8' }
