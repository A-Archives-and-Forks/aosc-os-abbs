From 0d81fca00a602fbd5924812055b4c939503ff5e3 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 26 Mar 2025 11:41:59 +0800
Subject: [PATCH 4/7] FEDORA: lib: src: fix C99 compatibility with newer
 compilers

Fix C99 compatibility issues (#2164996)

Related to:

  <https://fedoraproject.org/wiki/Changes/PortingToModernC>
  <https://fedoraproject.org/wiki/Toolchain/PortingToModernC>

Add additional #include directives to avoid implicit function
declarations and build failures with future compilers.

Signed-off-by: Florian Weimer <fweimer@redhat.com>

Link: https://src.fedoraproject.org/rpms/lrzsz/blob/733386dd8dde1fdde728d2b7f127b2108b5dd57e/f/lrzsz-c99.patch
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 lib/long-options.c | 1 +
 src/lsyslog.c      | 2 ++
 2 files changed, 3 insertions(+)

diff --git a/lib/long-options.c b/lib/long-options.c
index 76b9796..9ee8f66 100644
--- a/lib/long-options.c
+++ b/lib/long-options.c
@@ -22,6 +22,7 @@
 #endif
 
 #include <stdio.h>
+#include <stdlib.h>
 #include <getopt.h>
 #include "long-options.h"
 
diff --git a/src/lsyslog.c b/src/lsyslog.c
index 6baf4a2..0500280 100644
--- a/src/lsyslog.c
+++ b/src/lsyslog.c
@@ -18,11 +18,13 @@
   02111-1307, USA.
 
 */
+#define _GNU_SOURCE /* for vasprintf */
 #include "config.h"
 #ifdef ENABLE_SYSLOG
 #include "zglobal.h"
 #include <pwd.h>
 #include <stdlib.h>
+#include <stdio.h>
 #include <string.h>
 #endif
 
-- 
2.49.0

