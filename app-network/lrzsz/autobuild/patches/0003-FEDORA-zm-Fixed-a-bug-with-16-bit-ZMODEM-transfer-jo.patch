From 30d48252c25da813ab679a8bf465bb1a036789db Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 26 Mar 2025 11:40:26 +0800
Subject: [PATCH 3/7] FEDORA: zm: Fixed a bug with 16 bit ZMODEM transfer,
 jordanc@censoft.com (bug #75473)

Signed-off-by: jordanc@censoft.com

Link: https://src.fedoraproject.org/rpms/lrzsz/blob/f637be2e4411065acb35256f130ddedb2613aab6/f/lrzsz-0.12.20.patch
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 src/zm.c | 10 ++++++----
 1 file changed, 6 insertions(+), 4 deletions(-)

diff --git a/src/zm.c b/src/zm.c
index 56af141..fe82b64 100644
--- a/src/zm.c
+++ b/src/zm.c
@@ -431,10 +431,12 @@ zsdata(const char *buf, size_t length, int frameend)
 	VPRINTF(3,("zsdata: %lu %s", (unsigned long) length, 
 		Zendnames[(frameend-ZCRCE)&3]));
 	crc = 0;
-	do {
-		zsendline(*buf); crc = updcrc((0377 & *buf), crc);
-		buf++;
-	} while (--length>0);
+
+	for( ; length; length--) {
+	  zsendline(*buf); crc = updcrc((0377 & *buf), crc);
+	  buf++;
+	}
+
 	xsendline(ZDLE); xsendline(frameend);
 	crc = updcrc(frameend, crc);
 
-- 
2.49.0

