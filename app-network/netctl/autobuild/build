abinfo "Building netctl ..."
make

abinfo "Installing netctl ..."
make install \
    DESTDIR="$PKGDIR" \
    PREFIX="/usr"

abinfo "Installing completion files ..."
install -Dvm644 "$SRCDIR"/contrib/bash-completion \
    "$PKGDIR"/usr/share/bash-completion/completions/netctl
install -Dvm644 "$SRCDIR"/contrib/zsh-completion \
    "$PKGDIR"/usr/share/zsh/site-functions/_netctl

