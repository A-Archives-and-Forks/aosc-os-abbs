abinfo "Building zsync ..."
go build \
    -o zsync \
    "$SRCDIR"/cmd/zsync

abinfo "Building zsyncmake ..."
go build \
    -o zsyncmake \
    "$SRCDIR"/cmd/zsyncmake

abinfo "Installing executables ..."
install -Dvm755 "$SRCDIR"/zsync "$SRCDIR"/zsyncmake \
    -t "$PKGDIR"/usr/bin/
install -Dvm755 "$SRCDIR"/man/zsync.1 "$SRCDIR"/man/zsyncmake.1 \
    -t "$PKGDIR"/usr/share/man/man1/
