# FIXME: Must be dynamically generated as $PKGDIR is a build-time variable.
abinfo "Fixing up installation prefix ..."
sed -e "s:install --basedir=\$\$dir:install --basedir=\$\$dir --root=${PKGDIR}:" \
    -i "$SRCDIR"/Makefile

abinfo "Re-running make install ..."
make install \
    DESTDIR="$PKGDIR" \
    INSTALL_PREFIX="$PKGDIR" \
    INSTALLDIRS=vendor

abinfo "Setting executable bits on shared objects ..."
chmod -v +x "$PKGDIR"/usr/lib/*.so*
