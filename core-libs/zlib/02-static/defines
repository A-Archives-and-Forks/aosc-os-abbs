PKGNAME=zlib-static
PKGDES="Data compression library with SIMD optimizations (static library)"
PKGDEP="zlib"
PKGSEC=libs

NOSTATIC=0

ABTYPE=cmakeninja
CMAKE_AFTER=(
        '-DBUILD_SHARED_LIBS=OFF'
        '-DZLIB_COMPAT=ON'
        '-DWITH_GZFILEOP=ON'
        '-DWITH_OPTIM=ON'
        '-DWITH_NEW_STRATEGIES=ON'
        '-DWITH_RUNTIME_CPU_DETECTION=ON'
)
CMAKE_AFTER__LOONGARCH64_NOSIMD=(
        "${CMAKE_AFTER[@]}"
        '-DWITH_LSX=OFF'
        '-DWITH_LASX=OFF'
)

ABSPLITDBG=0
