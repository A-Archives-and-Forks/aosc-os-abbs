From e0b4d34aa09d4603aacae218acf5d7fec7ede68c Mon Sep 17 00:00:00 2001
From: CAB233 <yidaduizuoye@outlook.com>
Date: Mon, 17 Nov 2025 13:53:02 +0800
Subject: [PATCH 2/2] LoongArch64: migrate to new world

---
 configure.ac                 |  8 ++++--
 mono/metadata/mono-config.c  |  2 +-
 mono/mini/mini-arch.h        |  2 +-
 mono/sgen/sgen-archdep.h     |  2 +-
 mono/utils/mono-context.c    | 54 +++++++++++++++++++++++++++++++++---
 mono/utils/mono-context.h    |  2 +-
 mono/utils/mono-sigcontext.h |  3 +-
 7 files changed, 61 insertions(+), 12 deletions(-)

diff --git a/configure.ac b/configure.ac
index d428244c681..df3920c4f01 100644
--- a/configure.ac
+++ b/configure.ac
@@ -372,6 +372,10 @@ case "$host" in
 			support_boehm=no
 			with_gc=sgen
 			;;
+		loongarch64*)
+			support_boehm=no
+			with_gc=sgen
+			;;
 		esac
 		with_sgen_default_concurrent=yes
 		;;
@@ -4641,7 +4645,7 @@ case "$host" in
 		;;
 	loongarch64-*)
 		TARGET=LOONGARCH64
-		AOT_SUPPORTED="yes"
+		AOT_SUPPORTED="no"
 		BTLS_SUPPORTED=yes
 		BTLS_PLATFORM=loongarch64
 		arch_target=loongarch64
@@ -4887,7 +4891,7 @@ esac
 MONO_ARCH_GSHAREDVT_SUPPORTED=0
 case "$HOST" in
 X86 | AMD64 | ARM | ARM64 | LOONGARCH64)
-	MONO_ARCH_GSHAREDVT_SUPPORTED=1 # keep in sync with mini-{x86,amd64,arm,arm64}.h
+	MONO_ARCH_GSHAREDVT_SUPPORTED=1 # keep in sync with mini-{x86,amd64,arm,arm64,loongarch64}.h
 	;;
 esac
 
diff --git a/mono/metadata/mono-config.c b/mono/metadata/mono-config.c
index 105dec710fd..b66f9f03940 100644
--- a/mono/metadata/mono-config.c
+++ b/mono/metadata/mono-config.c
@@ -95,7 +95,7 @@
 #elif defined(TARGET_WASM)
 #define CONFIG_CPU "wasm"
 #define CONFIG_WORDSIZE "32"
-#elif defined(__loongarch64) || defined(TARGET_LOONGARCH64)
+#elif defined(__loongarch_lp64) || defined(TARGET_LOONGARCH64)
 #define CONFIG_CPU "loongarch64"
 #define CONFIG_WORDSIZE "64"
 #else
diff --git a/mono/mini/mini-arch.h b/mono/mini/mini-arch.h
index 7bdbc7cbc0a..fb9ea16d3b1 100644
--- a/mono/mini/mini-arch.h
+++ b/mono/mini/mini-arch.h
@@ -23,7 +23,7 @@
 #include "mini-arm.h"
 #elif defined(TARGET_ARM64)
 #include "mini-arm64.h"
-#elif defined(__loongarch64)
+#elif defined(__loongarch_lp64)
 #include "mini-loongarch64.h"
 #elif defined(__mips__)
 #include "mini-mips.h"
diff --git a/mono/sgen/sgen-archdep.h b/mono/sgen/sgen-archdep.h
index 7768200e377..3fa98f8365a 100644
--- a/mono/sgen/sgen-archdep.h
+++ b/mono/sgen/sgen-archdep.h
@@ -71,7 +71,7 @@
 
 #define REDZONE_SIZE	0
 
-#elif defined(__loongarch64)
+#elif defined(__loongarch_lp64)
 
 #define REDZONE_SIZE	0
 
diff --git a/mono/utils/mono-context.c b/mono/utils/mono-context.c
index 38fb964c034..90dd9279f26 100644
--- a/mono/utils/mono-context.c
+++ b/mono/utils/mono-context.c
@@ -667,7 +667,7 @@ mono_monoctx_to_sigctx (MonoContext *mctx, void *sigctx)
 #endif
 }
 
-#elif (defined(__loongarch64) && !defined(MONO_CROSS_COMPILE)) || (defined(TARGET_LOONGARCH64))
+#elif (defined(__loongarch_lp64) && !defined(MONO_CROSS_COMPILE)) || (defined(TARGET_LOONGARCH64))
 
 #include <mono/utils/mono-context.h>
 #include <mono/utils/ftnptr.h>
@@ -681,9 +681,30 @@ mono_sigctx_to_monoctx (void *sigctx, MonoContext *mctx)
 	memcpy (mctx->regs, UCONTEXT_GREGS (sigctx), sizeof (host_mgreg_t) * 32);
 	mctx->pc = UCONTEXT_REG_PC (sigctx);
 	mctx->regs [loongarch_sp] = UCONTEXT_REG_SP (sigctx);
-	union __loongarch_mc_fp_state *fregs = (union __loongarch_mc_fp_state *)UCONTEXT_FPREGS (sigctx);
-	for (int i = 0; i < 32; i++) {
-		mctx->fregs [i] = fregs [i].__val64 [0];
+	struct sctx_info *info = (struct sctx_info *)&((ucontext_t *)sigctx)->uc_mcontext.__extcontext;
+	if (FPU_CTX_MAGIC == info->magic)
+	{
+		struct fpu_context *fpr = (struct fpu_context *)(info + 1);
+		memcpy(mctx->fregs, fpr->regs, sizeof(mctx->fregs));
+	}
+	else if (LSX_CTX_MAGIC == info->magic)
+	{
+		struct lsx_context *fpr = (struct lsx_context *)(info + 1);
+		memcpy(mctx->fregs, fpr->regs, sizeof(mctx->fregs));
+	}
+	else if (LASX_CTX_MAGIC == info->magic)
+	{
+		struct lasx_context *fpr = (struct lasx_context *)(info + 1);
+		memcpy(mctx->fregs, fpr->regs, sizeof(mctx->fregs));
+	}
+	else if (LBT_CTX_MAGIC == info->magic)
+	{
+		struct lbt_context *fpr = (struct lbt_context *)(info + 1);
+		memcpy(mctx->fregs, fpr->regs, sizeof(mctx->fregs));
+	}
+	else
+	{
+		g_error ("Unknown LoongArch64 context type: 0x%08x", info->magic);
 	}
 #endif
 }
@@ -697,6 +718,31 @@ mono_monoctx_to_sigctx (MonoContext *mctx, void *sigctx)
 	memcpy (UCONTEXT_GREGS (sigctx), mctx->regs, sizeof (host_mgreg_t) * 31);
 	UCONTEXT_REG_SET_PC (sigctx, mctx->pc);
 	UCONTEXT_REG_SET_SP (sigctx, mctx->regs [loongarch_sp]);
+	struct sctx_info *info = (struct sctx_info *)&((ucontext_t *)sigctx)->uc_mcontext.__extcontext;
+	if (FPU_CTX_MAGIC == info->magic)
+	{
+		struct fpu_context *fpr = (struct fpu_context *)(info + 1);
+		memcpy(fpr->regs, mctx->fregs, sizeof(mctx->fregs));
+	}
+	else if (LSX_CTX_MAGIC == info->magic)
+	{
+		struct lsx_context *fpr = (struct lsx_context *)(info + 1);
+		memcpy(fpr->regs, mctx->fregs, sizeof(mctx->fregs));
+	}
+	else if (LASX_CTX_MAGIC == info->magic)
+	{
+		struct lasx_context *fpr = (struct lasx_context *)(info + 1);
+		memcpy(fpr->regs, mctx->fregs, sizeof(mctx->fregs));
+	}
+	else if (LBT_CTX_MAGIC == info->magic)
+	{
+		struct lbt_context *fpr = (struct lbt_context *)(info + 1);
+		memcpy(fpr->regs, mctx->fregs, sizeof(mctx->fregs));
+	}
+	else
+	{
+		g_error ("Unknown LoongArch64 context type: 0x%08x", info->magic);
+	}
 #endif
 }
 
diff --git a/mono/utils/mono-context.h b/mono/utils/mono-context.h
index 8e423acb398..a5c5746bcc8 100644
--- a/mono/utils/mono-context.h
+++ b/mono/utils/mono-context.h
@@ -1058,7 +1058,7 @@ typedef struct {
 
 #define MONO_ARCH_HAS_MONO_CONTEXT (1)
 
-#elif (defined(__loongarch64) && !defined(MONO_CROSS_COMPILE)) || (defined(TARGET_LOONGARCH64))
+#elif (defined(__loongarch_lp64) && !defined(MONO_CROSS_COMPILE)) || (defined(TARGET_LOONGARCH64))
 
 #include <mono/arch/loongarch64/loongarch64-codegen.h>
 
diff --git a/mono/utils/mono-sigcontext.h b/mono/utils/mono-sigcontext.h
index 2153c1cad57..5b64b98ec87 100644
--- a/mono/utils/mono-sigcontext.h
+++ b/mono/utils/mono-sigcontext.h
@@ -563,7 +563,7 @@ typedef struct ucontext
 # define UCONTEXT_REG_Rn(ctx, n) (((ucontext_t *)(ctx))->uc_mcontext.gregs[(n)])
 # define UCONTEXT_IP(ctx)         (((ucontext_t *)(ctx))->uc_mcontext.psw.addr)
 
-#elif defined(__loongarch64)
+#elif defined(__loongarch_lp64)
 
 # if HAVE_UCONTEXT_H
 #  include <ucontext.h>
@@ -578,7 +578,6 @@ typedef struct ucontext
 	 } while (0)
 #endif
 
-# define UCONTEXT_FPREGS(ctx)	((double*)(((ucontext_t *)(ctx))->uc_mcontext.__fpregs))
 # define UCONTEXT_GREGS(ctx)	(((ucontext_t *)(ctx))->uc_mcontext.__gregs)
 # define UCONTEXT_REG_PC(ctx)	(((ucontext_t *)(ctx))->uc_mcontext.__pc)
 # define UCONTEXT_REG_SP(ctx)	(((ucontext_t *)(ctx))->uc_mcontext.__gregs [loongarch_sp])
-- 
2.51.2

