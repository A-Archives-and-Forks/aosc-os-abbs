From 33a06cfcca42fe1c4b2745e7e418fd73fa212b8b Mon Sep 17 00:00:00 2001
From: CAB233 <yidaduizuoye@outlook.com>
Date: Tue, 9 Sep 2025 21:29:21 +0800
Subject: [PATCH 1/2] fix runtime build issues on arm64 ...

... caused by missing a pointer cast

Co-Authored-By: liushuyu <liushuyu@gmail.com>
---
 mono/mini/exceptions-arm64.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/mono/mini/exceptions-arm64.c b/mono/mini/exceptions-arm64.c
index 0e786809d0d..b1d904aee1e 100644
--- a/mono/mini/exceptions-arm64.c
+++ b/mono/mini/exceptions-arm64.c
@@ -549,7 +549,7 @@ mono_arch_handle_exception (void *ctx, gpointer obj)
 	UCONTEXT_REG_R0 (sigctx) = (gsize)obj;
 
 	gpointer addr = (gpointer)handle_signal_exception;
-	UCONTEXT_REG_SET_PC (sigctx, addr);
+	UCONTEXT_REG_SET_PC (sigctx, (size_t)addr);
 	host_mgreg_t sp = UCONTEXT_REG_SP (sigctx) - MONO_ARCH_REDZONE_SIZE;
 	UCONTEXT_REG_SET_SP (sigctx, sp);
 #endif
-- 
