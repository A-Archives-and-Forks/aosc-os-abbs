abinfo "Installing theme assets ..."
mkdir -pv "$PKGDIR"/usr/share/{color-schemes,Kvantum,plasma/look-and-feel,sddm/themes,wallpapers,konsole}
cp -av look-and-feel "$PKGDIR"/usr/share/plasma/look-and-feel/Utterly-Nord
cp -av look-and-feel-solid "$PKGDIR"/usr/share/plasma/look-and-feel/Utterly-Nord-Solid
cp -av look-and-feel-light "$PKGDIR"/usr/share/plasma/look-and-feel/Utterly-Nord-Light
cp -av look-and-feel-light-solid "$PKGDIR"/usr/share/plasma/look-and-feel/Utterly-Nord-Light-Solid
cp -av *.colors "$PKGDIR"/usr/share/color-schemes/
cp -av wallpaper "$PKGDIR"/usr/share/wallpapers/Utterly-Nord
cp -av kvantum "$PKGDIR"/usr/share/Kvantum/Utterly-Nord
cp -av kvantum-solid "$PKGDIR"/usr/share/Kvantum/Utterly-Nord-Solid
cp -av kvantum-light "$PKGDIR"/usr/share/Kvantum/Utterly-Nord-Light
cp -av kvantum-light-solid "$PKGDIR"/usr/share/Kvantum/Utterly-Nord-Light-Solid
cp -av *.colorscheme "$PKGDIR"/usr/share/konsole/
cp -av sddm "$PKGDIR"/usr/share/sddm/themes/Utterly-Nord

abinfo "Fixing theme assets permission ..."
find "${PKGDIR}" -type d -exec chmod -Rv 755 {} +
find "${PKGDIR}" -type f -exec chmod -Rv 644 {} +
