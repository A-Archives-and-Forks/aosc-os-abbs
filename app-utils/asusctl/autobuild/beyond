abinfo "Installing udev rules..."
install -Dvm644 "$SRCDIR/data/asusd.rules" \
    "$PKGDIR/usr/lib/udev/rules.d/90-asusd.rules"

abinfo "Installing DBus policy..."
install -Dvm644 "$SRCDIR/data/asusd.conf" \
    "$PKGDIR/usr/share/dbus-1/system.d/asusd.conf"

abinfo "Installing aura configuration..."
install -Dvm644 "$SRCDIR/rog-aura/data/aura_support.ron" \
    "$PKGDIR/usr/share/asusd/aura_support.ron"
    
abinfo "Installing systemd services..."
install -Dvm644 "$SRCDIR/data/asusd.service" \
    "$PKGDIR/usr/lib/systemd/system/asusd.service"
install -Dvm644 "$SRCDIR/data/asus-shutdown.service" \
    "$PKGDIR/usr/lib/systemd/system/asus-shutdown.service"
install -Dvm644 "$SRCDIR/data/asusd-user.service" \
    "$PKGDIR/usr/lib/systemd/user/asusd-user.service"
