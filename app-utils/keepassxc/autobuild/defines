PKGNAME=keepassxc
PKGSEC=utils
PKGDES="Cross-platform community-driven port for \"KeePass Password Safe\""
PKGDEP="argon2 libgcrypt libsodium qrencode qt-5 quazip x11-lib \
        yubikey-manager zlib botan"
BUILDDEP="asciidoctor minizip"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DWITH_XC_ALL=ON'
    '-DWITH_TESTS=OFF'
    '-DWITH_XC_UPDATECHECK=OFF'
    '-DKEEPASSXC_BUILD_TYPE=Release'
    "-DGIT_HEAD_OVERRIDE='AOSC OS'"
)
