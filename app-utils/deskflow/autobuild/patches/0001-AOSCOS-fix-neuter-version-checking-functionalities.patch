     return Settings::isNativeMode();
 
-  if (key == Core::UpdateUrl)
-    return kUrlUpdateCheck;
-
   if (key == Server::ExternalConfigFile)
     return QStringLiteral("%1/%2-server.conf").arg(Settings::settingsPath(), kAppId);
 
