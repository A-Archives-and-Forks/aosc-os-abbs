From: Kaiyang Wu <self@origincode.me>
Date: Tue, 6 May 2025 20:34:14 -0700
Subject: [PATCH 3/4] add zh_CN and zh_TW translations for oma

Signed-off-by: Kaiyang Wu <self@origincode.me>
---
 po/zh_CN.po | 10 +++++++++-
 po/zh_TW.po | 10 +++++++++-
 2 files changed, 18 insertions(+), 2 deletions(-)

diff --git a/po/zh_CN.po b/po/zh_CN.po
index d9d334c1..e09d63e7 100644
--- a/po/zh_CN.po
+++ b/po/zh_CN.po
@@ -152,10 +152,18 @@ msgstr "最近使用"
 msgid "Delete the most recently used list"
 msgstr "清空“最近使用”列表"
 
-#: ../cleaners/dnf.xml ../cleaners/yum.xml ../cleaners/apt.xml
+#: ../cleaners/dnf.xml ../cleaners/yum.xml ../cleaners/oma.xml
 msgid "Package manager"
 msgstr "包管理器"
 
+#: ../cleaners/oma.xml
+msgid "Package cache"
+msgstr "软件包缓存"
+
+#: ../cleaners/oma.xml
+msgid "Delete system package cache"
+msgstr "删除系统软件包缓存"
+
 #: ../cleaners/dnf.xml
 msgid "Remove packages that were formerly dependencies"
 msgstr "删除曾作为依赖自动安装的安装包"
diff --git a/po/zh_TW.po b/po/zh_TW.po
index 4c79f3ba..77a72189 100644
--- a/po/zh_TW.po
+++ b/po/zh_TW.po
@@ -151,10 +151,18 @@ msgstr "最近使用檔案"
 msgid "Delete the most recently used list"
 msgstr "刪除最近使用檔案清單"
 
-#: ../cleaners/dnf.xml ../cleaners/yum.xml ../cleaners/apt.xml
+#: ../cleaners/dnf.xml ../cleaners/yum.xml ../cleaners/oma.xml
 msgid "Package manager"
 msgstr "軟體包管理員"
 
+#: ../cleaners/oma.xml
+msgid "Package cache"
+msgstr "軟體包快取"
+
+#: ../cleaners/oma.xml
+msgid "Delete system package cache"
+msgstr "刪除系統軟體包快取"
+
 #: ../cleaners/dnf.xml
 msgid "Remove packages that were formerly dependencies"
 msgstr "移除先前以相依關係安裝的軟體包"
