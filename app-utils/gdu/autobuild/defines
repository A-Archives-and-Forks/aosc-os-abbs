PKGNAME="gdu"
PKGSEC=utils
PKGDES="A CLI disk usage analyzer"
PKGDEP="gcc-runtime"
BUILDDEP="go"

ABTYPE=gomod

GO_PACKAGES=("cmd/gdu")
GO_LDFLAGS=(
    "-X github.com/dundee/gdu/v5/build.Version=$PKGVER"
    "-X github.com/dundee/gdu/v5/build.Time=$(date --utc +"%Y-%m-%dT%H:%M:%SZ")"
    "-X github.com/dundee/gdu/v5/build.User=AOSC"
)
