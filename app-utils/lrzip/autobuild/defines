PKGNAME=lrzip
PKGSEC=utils
PKGDEP="lzo zlib"
BUILDDEP="perl"
BUILDDEP__RETRO=""
BUILDDEP__AMD64="${BUILDDEP} nasm"
BUILDDEP__ARMV4="${BUILDDEP__RETRO}"
BUILDDEP__ARMV6HF="${BUILDDEP__RETRO}"
BUILDDEP__ARMV7HF="${BUILDDEP__RETRO}"
BUILDDEP__I486="${BUILDDEP__RETRO}"
BUILDDEP__LOONGSON2F="${BUILDDEP__RETRO}"
BUILDDEP__M68K="${BUILDDEP__RETRO}"
BUILDDEP__POWERPC="${BUILDDEP__RETRO}"
BUILDDEP__PPC64="${BUILDDEP__RETRO}"
PKGDES="A compression program optimized for large files"

# FIXME: Include paths passed to nasm is incorrect:
# nasm -I../ASM/x86/ -Dx64 -g -f elf64 -o 7zCrcOpt_asm.o /var/cache/acbs/build/acbs.m6cx6fv7/lrzip-0.651/lzma/ASM/x86/7zCrcOpt_asm.asm
# /var/cache/acbs/build/acbs.m6cx6fv7/lrzip-0.651/lzma/ASM/x86/7zCrcOpt_asm.asm:4: error: unable to open include file `7zAsm.asm': No such file or directory
ABSHADOW=0

AB_FLAGS_O3=1

# FIXME: Assembly support is x86 only. See lzma/ASM for details.
# FIXME: This is probably needed for all ports without assembly support, as
# this feature is enabled whenever nasm is present in the build environment.
AUTOTOOLS_AFTER=(
	"--enable-largefile"
	"--disable-asm"
	"--disable-static-bin"
	"--disable-doc"
)
AUTOTOOLS_AFTER__AMD64=(
	"${AUTOTOOLS_AFTER[@]}"
	"--enable-asm"
)
