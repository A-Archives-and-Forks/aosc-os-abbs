abinfo "Applying patches to Bitwarden ..."
cd "$SRCDIR"/bitwarden
ab_apply_patches "$SRCDIR"/autobuild/patches/*.patch.deferred.bitwarden

if ab_match_arch loongarch64; then
    ab_apply_patches "$SRCDIR"/autobuild/patches/*.patch.deferred.loongarch64.bitwarden
fi

if ab_match_arch loongarch64; then
    abinfo "Applying patches to Rust Lang libc ..."
    cd "$SRCDIR"/rust-lang-libc
    ab_apply_patches "$SRCDIR"/autobuild/patches/*.patch.deferred.loongarch64.rust-lang-libc
fi
