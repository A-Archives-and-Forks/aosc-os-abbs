From bd0f9e7c7d2eac5942dd71790609da94aad0d0ce Mon Sep 17 00:00:00 2001
From: pch666777 <1005100717@qq.com>
Date: Thu, 2 Oct 2025 08:59:23 +0800
Subject: [PATCH 2/4] Allow disable Doxygen doc

---
 CMakeLists.txt         | 6 ++++--
 etc/configure.cmake    | 2 ++
 srecord/CMakeLists.txt | 4 ++++
 3 files changed, 10 insertions(+), 2 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 9b8e0ff..79b330b 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -55,8 +55,10 @@ add_subdirectory(srec_info)
 enable_testing()
 add_subdirectory(test)
 
-# Documentation & Man Pages
-add_subdirectory(doc)
+if(WITH_DOXYGEN_DOC)
+	# Documentation & Man Pages
+	add_subdirectory(doc)
+endif()
 
 # Package SRecord
 include(CPack)
diff --git a/etc/configure.cmake b/etc/configure.cmake
index 343a70a..29c24da 100644
--- a/etc/configure.cmake
+++ b/etc/configure.cmake
@@ -103,6 +103,7 @@ option(_TANDEM_SOURCE ON)
 # Enable general extensions on Solaris.
 option(__EXTENSIONS__ ON)
 
+if(WITH_DOXYGEN_DOC)
 # Doxygen configuration
 find_package(Doxygen REQUIRED doxygen dot)
 
@@ -132,3 +133,4 @@ set(DOXYGEN_SORT_MEMBER_DOCS NO)
 set(DOXYGEN_SOURCE_BROWSER YES)
 set(DOXYGEN_STRIP_CODE_COMMENTS NO)
 set(DOXYGEN_GENERATE_HTML YES)
+endif()
diff --git a/srecord/CMakeLists.txt b/srecord/CMakeLists.txt
index 930dbf9..280a4f2 100644
--- a/srecord/CMakeLists.txt
+++ b/srecord/CMakeLists.txt
@@ -33,17 +33,21 @@ install(DIRECTORY ${CMAKE_CURRENT_SOURCE_DIR}
         DESTINATION ${CMAKE_INSTALL_INCLUDEDIR}
         FILES_MATCHING PATTERN "*.h")
 
+if(WITH_DOXYGEN_DOC)
 # Install the Doxygen output for the website
 install(DIRECTORY ${CMAKE_CURRENT_BINARY_DIR}/html
         DESTINATION ${CMAKE_INSTALL_DOCDIR}/htdocs/srecord
  	COMPONENT website)
+endif()
 
 # Generate config.h to suit local environment
 configure_file(config.h.in config.h @ONLY)
 configure_file(patchlevel.h.in patchlevel.h @ONLY)
 include_directories(${CMAKE_CURRENT_BINARY_DIR})
 
+if(WITH_DOXYGEN_DOC)
 # Generate doxygen content
 doxygen_add_docs(doxygen
                  ${LIB_SRECORD_HDR}
 		 ALL)
+endif()
-- 
2.51.0

