PKGNAME=polybar
PKGSEC=utils
PKGDEP="alsa-lib cairo curl libmpdclient libxcb pulseaudio \
        libnl xcb-util-cursor xcb-util-image xcb-util-wm \
        xcb-util-xrm libuv xcb-proto libxcb pulseaudio"
BUILDDEP="i3 jsoncpp packaging python-3"
PKGDES="Tool to create customisable status bars"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DBUILD_CONFIG=ON'
    '-DBUILD_DOC=OFF'
    '-DBUILD_DOC_HTML=OFF'
    '-DBUILD_DOC_MAN=ON'
    '-DBUILD_POLYBAR=ON'
    '-DBUILD_POLYBAR_MSG=ON'
    '-DBUILD_SHELL=ON'
    '-DBUILD_TESTS=OFF'
    '-DDISABLE_ALL=OFF'
)
