abinfo "Installing NPM dependencies ..."
cd "$SRCDIR"/coolercontrol-ui

if ab_match_arch loongarch64 \
  || ab_match_arch loongarch64_nosimd; then
    abinfo "Setting NPM registry to registry.loongnix.cn:5873 ..."
    npm set registry https://registry.loongnix.cn:5873

    # FIXME: npm error code EINTEGRITY
    rm -v package-lock.json
    npm install
else
    npm ci
fi

abinfo "Building web GUI ..."
npm run build

abinfo "Installing web GUI to coolercontrold ..."
cp -rv "$SRCDIR"/coolercontrol-ui/dist/* \
       "$SRCDIR"/coolercontrold/resources/app/
