diff --git a/onnxruntime/cmake/onnxruntime_nodejs.cmake b/onnxruntime/cmake/onnxruntime_nodejs.cmake
index cce0810c5b..ea85e37f17 100644
--- a/onnxruntime/cmake/onnxruntime_nodejs.cmake
+++ b/onnxruntime/cmake/onnxruntime_nodejs.cmake
@@ -35,6 +35,8 @@ else()
         set(NODEJS_BINDING_ARCH arm64)
     elseif(CMAKE_SYSTEM_PROCESSOR STREQUAL "x86_64")
         set(NODEJS_BINDING_ARCH x64)
+    elseif(CMAKE_SYSTEM_PROCESSOR STREQUAL "loongarch64")
+        set(NODEJS_BINDING_ARCH loong64)
     else()
         message(FATAL_ERROR "Unsupported target platform for Node.js binding:" ${onnxruntime_target_platform})
     endif()


diff --git a/onnxruntime/js/node/script/build.ts b/onnxruntime/js/node/script/build.ts
index b557368ed5..4c925cc4fb 100644
--- a/onnxruntime/js/node/script/build.ts
+++ b/onnxruntime/js/node/script/build.ts
@@ -17,8 +17,8 @@ if (CONFIG !== 'Debug' && CONFIG !== 'Release' && CONFIG !== 'RelWithDebInfo') {
   throw new Error(`unrecognized config: ${CONFIG}`);
 }
 // --arch=x64|ia32|arm64|arm
-const ARCH: 'x64' | 'ia32' | 'arm64' | 'arm' = buildArgs.arch || os.arch();
-if (ARCH !== 'x64' && ARCH !== 'ia32' && ARCH !== 'arm64' && ARCH !== 'arm') {
+const ARCH: 'x64' | 'ia32' | 'arm64' | 'arm' | "loong64" = buildArgs.arch || os.arch();
+if (ARCH !== 'x64' && ARCH !== 'ia32' && ARCH !== 'arm64' && ARCH !== 'arm' && ARCH !== 'loong64') {
   throw new Error(`unrecognized architecture: ${ARCH}`);
 }
 // --onnxruntime-build-dir=


