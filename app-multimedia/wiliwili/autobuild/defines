PKGNAME=wiliwili
PKGSEC="video"
PKGDES="A desktop client for Bilibili"
PKGDEP="curl dbus fmt gcc-runtime glibc hicolor-icon-theme libwebp mpv opencc \
        openssl sdl2 tinyxml2 zlib"

ABTYPE=cmakeninja
CMAKE_AFTER=(
    '-DINSTALL=ON'
    '-DPLATFORM_DESKTOP=ON'
    '-DUSE_GLFW=ON'
    '-DGLFW_BUILD_WAYLAND=ON'
    '-DGLFW_BUILD_X11=ON'
    '-DUSE_GLES2=OFF'
    '-DUSE_EGL=ON'
    '-DUSE_SYSTEM_CURL=ON'
    '-DUSE_SYSTEM_OPENCC=ON'
    '-DUSE_SYSTEM_FMT=ON'
    '-DUSE_SYSTEM_TINYXML2=ON'
    '-DUSE_SYSTEM_SDL2=ON'
    '-DBRLS_UNITY_BUILD=ON'
    '-DCMAKE_UNITY_BUILD_BATCH_SIZE=16'
)
