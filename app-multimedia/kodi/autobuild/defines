PKGNAME=kodi
PKGSEC=x11
PKGDEP="afpfs-ng bluez dcadec fribidi glew hicolor-icon-theme \
        libass libbluray libcdio libcec libjpeg-turbo libmicrohttpd \
        libnfs libplist libssh libva lirc lsb-release lzo mariadb \
        mesa-demos pillow pulseaudio samba shairplay simplejson sdl2 \
        taglib tinyxml udisks-2 unrar unzip upower yajl rtmpdump \
        pybluez cwiid flatbuffers fmt fstrcmp rapidjson mariadb libxslt \
        sndio spdlog waylandpp libinput libudfread dav1d tinyxml2 \
        giflib libpng"
BUILDDEP="boost cmake curl doxygen gperf jasper openjdk swig zip"
BUILDDEP__AMD64="${BUILDDEP} nasm yasm"
PKGDES="Media center application for home theatres"

ABTYPE=cmakeninja
# FIXME: Now set "-DENABLE_INTERNAL_FFMPEG=ON".
# High maintenance overhead for out-of-tree patches.
# Re-enable this after upstream release containing FFmpeg 8 is available.
CMAKE_AFTER=(
    "-DMARIADBCLIENT_INCLUDE_DIR=/usr/include/"
    "-DENABLE_AIRTUNES=ON"
    "-DENABLE_ALSA=ON"
    "-DENABLE_AVAHI=ON"
    "-DENABLE_BLURAY=ON"
    "-DENABLE_CEC=ON"
    "-DENABLE_DBUS=ON"
    "-DENABLE_DVDCSS=OFF"
    "-DENABLE_EVENTCLIENTS=ON"
    "-DENABLE_INTERNAL_FFMPEG=ON"
    "-DENABLE_INTERNAL_CROSSGUID=ON"
    "-DENABLE_INTERNAL_FSTRCMP=OFF"
    "-DENABLE_INTERNAL_FLATBUFFERS=OFF"
    "-DENABLE_INTERNAL_UDFREAD=OFF"
    "-DCORE_PLATFORM_NAME=x11"
    "-DENABLE_MICROHTTPD=ON"
    "-DENABLE_MYSQLCLIENT=ON"
    "-DENABLE_NFS=ON"
    "-DENABLE_OPTICAL=ON"
    "-DENABLE_PULSEAUDIO=ON"
    "-DENABLE_SMBCLIENT=ON"
    "-DENABLE_UDEV=ON"
    "-DENABLE_UPNP=ON"
    "-DENABLE_VAAPI=ON"
    "-DENABLE_XSLT=ON"
    "-DAPP_RENDER_SYSTEM=gl"
    "-DENABLE_TESTING=OFF"
)

# FIXME:
# /var/cache/acbs/build/acbs.vjpten8p/xbmc/abbuild/build/ffmpeg/src/ffmpeg-build/ffmpeg-prefix/src/ffmpeg-build/src/libavcodec/x86/lpc_init.c:78:(.text+0xc17): undefined reference to `pd_1'
# /usr/bin/ld: /var/cache/acbs/build/acbs.vjpten8p/xbmc/abbuild/build/ffmpeg/src/ffmpeg-build/ffmpeg-prefix/src/ffmpeg-build/src/libavcodec/x86/lpc_init.c:78:(.text+0xc1f): undefined reference to `pd_1' 
NOLTO__AMD64=1

# FIXME: Use internal FFmpeg, 
# support is restored when `-DENABLE_INTERNAL_FFMPEG=OFF` is set.
FAIL_ARCH="(loongarch64_nosimd|loongson3)"
