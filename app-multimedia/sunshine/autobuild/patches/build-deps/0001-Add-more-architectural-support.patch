From f130c15b87b5cdf6dd275db904142d1b22407046 Mon Sep 17 00:00:00 2001
From: CAB233 <yidaduizuoye@outlook.com>
Date: Tue, 4 Mar 2025 12:22:52 +0800
Subject: [PATCH 1/2] Add more architectural support

---
 cmake/ffmpeg/ffmpeg.cmake | 6 +++++-
 cmake/ffmpeg/x264.cmake   | 6 +++++-
 2 files changed, 10 insertions(+), 2 deletions(-)

diff --git a/cmake/ffmpeg/ffmpeg.cmake b/cmake/ffmpeg/ffmpeg.cmake
index 4650691..e86b004 100644
--- a/cmake/ffmpeg/ffmpeg.cmake
+++ b/cmake/ffmpeg/ffmpeg.cmake
@@ -12,8 +12,12 @@ elseif (${arch} STREQUAL "ppc64le")
     set(CBS_ARCH_PATH ppc)
 elseif (${arch} STREQUAL "amd64" OR ${arch} STREQUAL "x86_64")
     set(CBS_ARCH_PATH x86)
-elseif (${arch} STREQUAL "mips")
+elseif (${arch} STREQUAL "mips" OR ${arch} STREQUAL "mips64")
     set(CBS_ARCH_PATH mips)
+elseif (${arch} STREQUAL "loongarch64")
+    set(CBS_ARCH_PATH loongarch)
+elseif (${arch} STREQUAL "riscv64")
+    set(CBS_ARCH_PATH riscv)
 else()
     message(FATAL_ERROR "Unsupported system processor:" ${CMAKE_SYSTEM_PROCESSOR})
 endif()
diff --git a/cmake/ffmpeg/x264.cmake b/cmake/ffmpeg/x264.cmake
index 16d90e0..73877ff 100644
--- a/cmake/ffmpeg/x264.cmake
+++ b/cmake/ffmpeg/x264.cmake
@@ -12,8 +12,12 @@ elseif (${arch} STREQUAL "ppc64le")
     set(X264_ARCH powerpc64le)
 elseif (${arch} STREQUAL "amd64" OR ${arch} STREQUAL "x86_64")
     set(X264_ARCH x86_64)
-elseif (${arch} STREQUAL "mips")
+elseif (${arch} STREQUAL "mips" OR ${arch} STREQUAL "loongson3")
     set(X264_ARCH mips)  # TODO: unknown if this is the correct value
+elseif (${arch} STREQUAL "loongarch64")
+    set(X264_ARCH loongarch)
+elseif (${arch} STREQUAL "riscv64")
+    set(X264_ARCH riscv)
 else()
     message(FATAL_ERROR "Unsupported system processor:" ${CMAKE_SYSTEM_PROCESSOR})
 endif()
-- 
2.48.1

