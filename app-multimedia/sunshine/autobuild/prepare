abinfo "Preparing NPM modules ..."
npm install --package-lock-only

abinfo "Patching to support more architectural ..."
cd "$SRCDIR"/../build-deps
patch -d . -p1 < "${SRCDIR}/autobuild/patches/build-deps\
0001-Add-more-architectural-support.patch"

if  ! ab_match_arch amd64 && \
    ! ab_match_arch arm64; then
    abinfo "Updating config.guess for x264 ..."
    cp -v /usr/bin/config.guess third-party/FFmpeg/x264/config.guess

    abinfo "Patching to disable cuda and ffnvcodec ..."
    patch -d . -p1 < "${SRCDIR}/autobuild/patches/build-deps\
0002-Disable-cuda-and-ffnvcodec-on-specific-platforms.patch"

    abinfo "Building sunshine static dependences ..."
    cmake \
        -B build \
        -S . \
        -G "Unix Makefiles" \
        -DCMAKE_INSTALL_PREFIX=/opt \
        -DBUILD_FFMPEG_NV_CODEC_HEADERS=OFF \
        -DBUILD_FFMPEG_NV_CODEC_HEADERS_PATCHES=OFF
    make -C build install
else
    abinfo "Building sunshine static dependences ..."
    cmake \
        -B build \
        -S . \
        -G "Unix Makefiles" \
        -DCMAKE_INSTALL_PREFIX=/opt
    make -C build install
fi
