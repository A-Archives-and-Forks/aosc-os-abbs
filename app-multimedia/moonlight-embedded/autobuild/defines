PKGNAME=moonlight-embedded
PKGDES="An open source embedded-Linux-optimized client for NVIDIA GameStream"
PKGSEC=video
PKGDEP="alsa-lib pulseaudio opus sdl2 ffmpeg libvdpau libva libglvnd \
        libcec libevdev curl openssl util-linux"

ABTYPE=cmakeninja
# FIXME: Override CMAKE_INSTALL_SYSCONFDIR for consistency with manpage.
CMAKE_AFTER=(
    '-DCMAKE_INSTALL_SYSCONFDIR=/etc/moonlight'
    '-DENABLE_SDL=ON'
    '-DENABLE_FFMPEG=ON'
    '-DENABLE_X11=ON'
    '-DENABLE_CEC=ON'
    '-DENABLE_PULSE=ON'
)
