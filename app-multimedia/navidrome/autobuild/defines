PKGNAME=navidrome
PKGSEC="sound"
PKGDES="Personal streaming service"
PKGDEP="ffmpeg gcc-runtime glibc taglib zlib"
BUILDDEP="nodejs go"

ABTYPE=gomod

GO_BUILD_AFTER=(
    "-tags=netgo"
)
GO_LDFLAGS=(
    "-X github.com/navidrome/navidrome/consts.gitSha=$(git rev-parse HEAD)"
    "-X github.com/navidrome/navidrome/consts.gitTag=$PKGVER"
)

# FIXME: Vite not supported on loongson3, riscv64.
FAIL_ARCH="(loongson3|riscv64)"
