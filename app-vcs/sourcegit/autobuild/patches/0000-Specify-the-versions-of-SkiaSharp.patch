From 5512351b196f69348c47157883280f592c769c5a Mon Sep 17 00:00:00 2001
From: LiarOnce <liaronce@hotmail.com>
Date: Tue, 30 Jun 2026 17:13:18 +0800
Subject: [PATCH] Specify the versions of SkiaSharp and HarfbuzzSharp

Starting with 2026.14, the upstream will downgrade AvaloniaUI to version 11.3.18
to address significant performance issues that have persisted since Avalonia 12.
To ensure compatibility with LoongArch and RISC-V, we will need to manually
specify the versions of SkiaSharp and HarfBuzzSharp.

Signed-off-by: LiarOnce <liaronce@hotmail.com>
---
 src/SourceGit.csproj | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/src/SourceGit.csproj b/src/SourceGit.csproj
index fc8fe02d..8c4f4d2d 100644
--- a/src/SourceGit.csproj
+++ b/src/SourceGit.csproj
@@ -61,6 +61,11 @@
     <PackageReference Include="Pfim" Version="0.11.4" />
     <PackageReference Include="StbImageSharp" Version="2.30.15" />
 
+    <PackageReference Include="SkiaSharp" Version="3.119.4" />
+    <PackageReference Include="SkiaSharp.NativeAssets.Linux" Version="3.119.4" />
+    <PackageReference Include="HarfBuzzSharp" Version="8.3.1.5" />
+    <PackageReference Include="HarfBuzzSharp.NativeAssets.Linux" Version="8.3.1.5" />
+    
     <ProjectReference Include="../depends/AvaloniaEdit/src/AvaloniaEdit.TextMate/AvaloniaEdit.TextMate.csproj" />
   </ItemGroup>
 
-- 
2.52.0

