abinfo "Building and installing redis ..."
make all \
    BUILD_TLS=yes \
    USE_SYSTEMD=yes

abinfo "Installing redis ..."
make install \
    PREFIX="$PKGDIR/usr"

abinfo "Installing config files ..."
install -Dvm644 "$SRCDIR"/redis.conf "$PKGDIR"/etc/redis.conf
install -Dvm644 "$SRCDIR"/sentinel.conf "$PKGDIR"/etc/sentinel.conf
