From f0ae8d7d798dd936b2092dbe6b07ff5439060eeb Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Sun, 7 Jun 2026 13:37:26 +0800
Subject: [PATCH] AOSCOS: ncdump: drop true/false enum constraints to fix build
 with GCC >= 15
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

From GCC 15, the compiler defauls to C23:

  utils.h:21:7: note: ‘false’ is a keyword with ‘-std=c23’ onwards
  In file included from chunkspec.c:12:
  utils.h:21:7: error: cannot use keyword ‘false’ as enumeration constant
     21 | enum {false=0, true=1};
        |       ^~~~~

Take partial change from commit 3ffe7be4464d ("Enhance/Fix filter
support") to fix build.

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 ncdump/utils.h | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/ncdump/utils.h b/ncdump/utils.h
index 4d187920c..0eb452692 100644
--- a/ncdump/utils.h
+++ b/ncdump/utils.h
@@ -18,7 +18,12 @@
 #define NC_GRP_DELIM '/'
 
 typedef int bool_t;
-enum {false=0, true=1};
+#ifndef false
+#define false 0
+#endif
+#ifndef true
+#define true 1
+#endif
 
 struct safebuf_t;
 /* Buffer structure for implementing growable strings, used in
-- 
2.52.0

