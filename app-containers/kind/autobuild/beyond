abinfo "Installing kind shell completions..."
"$PKGDIR"/usr/bin/kind completion bash | \
	install -Dvm644 /dev/stdin \
	"$PKGDIR"/usr/share/bash-completion/completions/kind
"$PKGDIR"/usr/bin/kind completion zsh | \
	install -Dvm644 /dev/stdin \
	"$PKGDIR"/usr/share/zsh/site-functions/_kind
"$PKGDIR"/usr/bin/kind completion fish | \
	install -Dvm644 /dev/stdin \
	"$PKGDIR"/usr/share/fish/vendor_completions/kind.fish
