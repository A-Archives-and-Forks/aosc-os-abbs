abinfo "Installing Incus shell completions..."
"$PKGDIR"/usr/bin/incus completion bash | install -v -Dm644 /dev/stdin \
	"$PKGDIR"/usr/share/bash-completion/completions/incus
"$PKGDIR"/usr/bin/incus completion zsh | install -v -Dm644 /dev/stdin \
	"$PKGDIR"/usr/share/zsh/site-functions/_incus
"$PKGDIR"/usr/bin/incus completion fish | install -v -Dm644 /dev/stdin \
	"$PKGDIR"/usr/share/fish/vendor_completions.d/incus.fish
