abinfo "Building kubeadm ..."
FORCE_HOST_GO=1 make kubeadm

abinfo "Installing kubeadm ..."
install -Dvm755 "$SRCDIR"/_output/bin/kubeadm -t "$PKGDIR"/usr/bin

abinfo "Installing bash and zsh completions ..."
"$PKGDIR"/usr/bin/kubeadm completion bash | \
install -Dvm644 /dev/stdin "$PKGDIR"/usr/share/bash-completion/completions/kubeadm
"$PKGDIR"/usr/bin/kubeadm completion zsh | \
install -Dvm644 /dev/stdin "$PKGDIR"/usr/share/zsh/site-functions/_kubeadm
