From cf96173e92d27bbf78ba1f7469be7ef12c2625e4 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 29 Oct 2025 10:40:11 +0800
Subject: [PATCH 2/2] AOSCOS: fix(src/Makefile): drop strip on install

This allows Autobuild to generate the needed debug symbol packages.

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 src/Makefile | 3 ---
 1 file changed, 3 deletions(-)

diff --git a/src/Makefile b/src/Makefile
index 72986407c..234f66a76 100644
--- a/src/Makefile
+++ b/src/Makefile
@@ -276,9 +276,6 @@ endif
 
 ifeq ($(DEBUG),0)
 CFLAGS                  += -O2
-ifneq ($(UNAME),Darwin)
-LFLAGS                  += -s
-endif
 else
 ifeq ($(DEBUG),1)
 ifneq ($(UNAME),Darwin)
-- 
2.51.1

