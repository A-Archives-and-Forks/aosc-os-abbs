From a8e7b7ac8f39b041318fee3907a3f2039b101b92 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 29 Oct 2025 10:38:29 +0800
Subject: [PATCH 1/2] AOSCOS: fix: drop -march=native from default flags

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 src/bridges/bridge_argon2id_reference.mk | 2 --
 src/bridges/bridge_scrypt_jane.mk        | 2 --
 src/bridges/bridge_scrypt_yescrypt.mk    | 2 --
 3 files changed, 6 deletions(-)

diff --git a/src/bridges/bridge_argon2id_reference.mk b/src/bridges/bridge_argon2id_reference.mk
index e47a4fc76..90b1d02b8 100644
--- a/src/bridges/bridge_argon2id_reference.mk
+++ b/src/bridges/bridge_argon2id_reference.mk
@@ -10,8 +10,6 @@ ifeq ($(UNAME),Darwin)
 ifeq ($(IS_APPLE_SILICON),0)
 ARGON2_REFERENCE_CFLAGS += -mavx2
 endif
-else
-ARGON2_REFERENCE_CFLAGS += -march=native
 endif
 endif
 endif
diff --git a/src/bridges/bridge_scrypt_jane.mk b/src/bridges/bridge_scrypt_jane.mk
index d92b99aba..795c36de5 100644
--- a/src/bridges/bridge_scrypt_jane.mk
+++ b/src/bridges/bridge_scrypt_jane.mk
@@ -10,8 +10,6 @@ ifeq ($(UNAME),Darwin)
 ifeq ($(IS_APPLE_SILICON),0)
 SCRYPT_JANE_CFLAGS += -mavx2
 endif
-else
-SCRYPT_JANE_CFLAGS += -march=native
 endif
 endif
 endif
diff --git a/src/bridges/bridge_scrypt_yescrypt.mk b/src/bridges/bridge_scrypt_yescrypt.mk
index d5254ec27..ed3b9e5e1 100644
--- a/src/bridges/bridge_scrypt_yescrypt.mk
+++ b/src/bridges/bridge_scrypt_yescrypt.mk
@@ -10,8 +10,6 @@ ifeq ($(UNAME),Darwin)
 ifeq ($(IS_APPLE_SILICON),0)
 SCRYPT_YESCRYPT_CFLAGS += -mavx2
 endif
-else
-SCRYPT_YESCRYPT_CFLAGS += -march=native
 endif
 endif
 endif
-- 
