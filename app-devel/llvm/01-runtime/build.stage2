abinfo "Installing symlinks for the default llvm-runtime ..."
mkdir -pv "$PKGDIR"/usr/lib
cd /usr/lib/llvm-"${PKGVER%%.*}"/lib/
for filename in *; do
    # skip symlinks that already exist
    if [ ! -e /usr/lib/"$filename" ]; then
        ln -sv llvm-"${PKGVER%%.*}"/lib/"$filename" "$PKGDIR"/usr/lib
    fi
done

abinfo "Asserting that key symlinks exist ..."
for i in lib{clang{,-cpp},LLVM,LTO}.so; do
    abinfo "Checking $i ..."
    test -L "$PKGDIR"/usr/lib/"$i"
done
