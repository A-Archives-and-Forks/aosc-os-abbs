From 9bff4fc3798d603d3870b90c309d1b8cb5e663c2 Mon Sep 17 00:00:00 2001
From: Xinhui Yang <cyan@cyano.uk>
Date: Tue, 11 Mar 2025 09:54:14 +0800
Subject: [PATCH 86/89] AOSC: gcc/Makefile.in: do not run fixinc.sh

This came from one of the sed commands in GCC's autobuild/prepare
script.
---
 gcc/Makefile.in | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/gcc/Makefile.in b/gcc/Makefile.in
index 1d9e10127ca..c7188ad8eaa 100644
--- a/gcc/Makefile.in
+++ b/gcc/Makefile.in
@@ -3290,7 +3290,7 @@ stmp-fixinc: gsyslimits.h macro_list fixinc_list \
 	      gcc_dir=`${PWD_COMMAND}` ; \
 	      export TARGET_MACHINE srcdir SHELL MACRO_LIST && \
 	      cd $(build_objdir)/fixincludes && \
-	      $(SHELL) ./fixinc.sh "$${gcc_dir}/$${fix_dir}" \
+	      $(SHELL) -c true "$${gcc_dir}/$${fix_dir}" \
 	        $(BUILD_SYSTEM_HEADER_DIR) $(OTHER_FIXINCLUDES_DIRS) ); \
 	  done; \
 	fi
-- 
2.50.1

