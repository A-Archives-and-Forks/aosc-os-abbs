abinfo "Clearing compiler flags in environment..."
unset CFLAGS CXXFLAGS CPPFLAGS LDFLAGS

abinfo "Configuring Binutils (target: arm-none-eabi) ..."
mkdir -pv "$SRCDIR"/build-${__CROSS}
cd "$SRCDIR"/build-${__CROSS}

BUILD_OPTIONS="""
    --prefix=/opt/abcross/${__CROSS}
    --build=arm-none-eabi
    --target=arm-none-eabi
    --with-sysroot=/var/ab/cross-root/${__CROSS}
    --with-bugurl=https://github.com/AOSC-Dev/aosc-os-abbs
    --enable-threads
    --enable-shared
    --with-pic
    --enable-ld
    --enable-plugins
    --disable-werror
    --enable-lto
    --disable-gdb
    --disable-gdbserver
    --enable-deterministic-archives
    --enable-64-bit-bfd
    --enable-interwork
    --enable-default-hash-style=gnu 
"""

# Note: loongson3-specific options.
if [[ "${__CROSS}" = "loongson3" ]]; then
    BUILD_OPTIONS+="""
        --enable-mips-fix-loongson3-llsc
    """
fi

"$SRCDIR"/configure \
    ${BUILD_OPTIONS}

abinfo "Building Binutils (target: arm-none-eabi) ..."
make configure-host
make

abinfo "Installing Binutils (target: arm-none-eabi) ..."
make install \
    DESTDIR="$PKGDIR"

abinfo "Dropping texinfo dir index ..."
rm -v "$PKGDIR"/opt/abcross/${__CROSS}/share/info/dir

abinfo "Creating host-prefixed symlinks (target: arm-none-eabi) ..."
mkdir -pv "$PKGDIR"/usr/bin
cd "$PKGDIR"/opt/abcross/${__CROSS}/bin/
for i in *; do
    ln -sv $i arm-none-eabi-$i
    ln -sv ../../opt/abcross/${__CROSS}/bin/$i \
        "$PKGDIR"/usr/bin/arm-none-eabi-$i
done
