abinfo "Installing shell completion scripts..."
"$PKGDIR"/usr/bin/gh completion -s bash | \
    install -Dvm644 /dev/stdin "$PKGDIR"/usr/share/bash-completion/completions/gh
"$PKGDIR"/usr/bin/gh completion -s zsh | \
    install -Dvm644 /dev/stdin "$PKGDIR"/usr/share/zsh/site-functions/_gh
"$PKGDIR"/usr/bin/gh completion -s fish | \
    install -Dvm644 /dev/stdin "$PKGDIR"/usr/share/fish/vendor_completions.d/gh.fish

abinfo "Installing manpages..."
mkdir -pv "$PKGDIR"/usr/share/man/man1/
go run "$SRCDIR"/cmd/gen-docs --man-page --doc-path "$PKGDIR"/usr/share/man/man1/
