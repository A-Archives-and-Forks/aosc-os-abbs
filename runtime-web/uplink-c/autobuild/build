abinfo "Building uplink-c ..."
make build

abinfo "Installing uplink-c ..."
install -Dvm644 "$SRCDIR"/.build/libuplink.pc \
    "$PKGDIR"/usr/lib/pkgconfig/libuplink.pc
install -Dvm755 "$SRCDIR"/.build/libuplink.so \
    "$PKGDIR"/usr/lib/libuplink.so
install -dvm755 "$PKGDIR"/usr/include
cp -av "$SRCDIR"/.build/uplink \
    -t "$PKGDIR"/usr/include/
