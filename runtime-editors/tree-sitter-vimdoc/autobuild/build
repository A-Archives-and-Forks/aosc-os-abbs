abinfo "Building tree-sitter-vimdoc ..."
make

abinfo "Installing tree-sitter-vimdoc ..."
make install \
    DESTDIR="$PKGDIR" \
    PREFIX="/usr"

abinfo "Symlinking the library ..."
install -dv "$PKGDIR"/usr/lib/tree_sitter
ln -sv ../libtree-sitter-vimdoc.so "$PKGDIR"/usr/lib/tree_sitter/vimdoc.so
