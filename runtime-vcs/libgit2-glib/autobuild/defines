PKGNAME=libgit2-glib
PKGSEC=libs
PKGDEP="glib libgit2 pygobject-3"
BUILDDEP="gobject-introspection vala"
PKGDES="GLib wrapper for Git"
PKGBREAK="gitg<=41 gnome-builder<=42.1-8"

ABTYPE=meson
MESON_AFTER=(
    '-Dgtk_doc=false'
    '-Dintrospection=true'
    '-Dpython=true'
    '-Dssh=true'
    '-Dvapi=true'
    '-Dtranslate_windows_paths=true'
)
