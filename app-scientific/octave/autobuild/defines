PKGNAME=octave
PKGSEC=math
PKGDEP="arpack-ng curl fftw fltk ghostscript glpk glu gnuplot graphicsmagick \
        hdf5 libsndfile qhull qscintilla suitesparse texinfo openjdk qt-5 \
        openblas gl2ps"
PKGDES="A high-level language intended for numerical computations"

JAVA_HOME="/usr/lib/java"
if [ -d "$JAVA_HOME/lib/server" ]; then
    JAVA_LIBDIR="$JAVA_HOME/lib/server"
elif [ -d "$JAVA_HOME/lib/zero" ]; then
    JAVA_LIBDIR="$JAVA_HOME/lib/zero"
elif [ -d "$JAVA_HOME/lib/client" ]; then
    JAVA_LIBDIR="$JAVA_HOME/lib/client"
fi

ABTYPE=autotools
AUTOTOOLS_AFTER=(
	--libexecdir=/usr/lib
	--enable-float-truncate
	--with-qrupdate
	--with-cxsparse
	--with-amd
	--with-umfpack
	--with-colamd
	--with-ccolamd
	--with-cholmod
	--with-cxsparse
	--with-blas=openblas
	--disable-docs
        --with-java-homedir=${JAVA_HOME}
        --with-java-libdir=${JAVA_LIBDIR}
)

AB_FLAGS_O3=1
