Subject: [PATCH] disable sharq due to re2 desperated StringPiece

- Link: https://github.com/google/re2
- In commit 49d776b,
- StringPiece was desperated and is now an alias for std::string_view
- To fix rebuild sra-tools, disable sharq
---
 tools/loaders/CMakeLists.txt | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/tools/loaders/CMakeLists.txt b/tools/loaders/CMakeLists.txt
index 39aa244..d3aa892 100644
--- a/tools/loaders/CMakeLists.txt
+++ b/tools/loaders/CMakeLists.txt
@@ -26,7 +26,7 @@ add_subdirectory( bam-loader )
 add_subdirectory( kar )
 add_subdirectory( sra-sort )
 add_subdirectory( fastq-loader )
-add_subdirectory( sharq )
+#add_subdirectory( sharq )
 add_subdirectory( sra-load )
 add_subdirectory( pacbio-load )
 add_subdirectory( cg-load )
