abinfo "Building lpsolve ..."
cd "$SRCDIR"/lpsolve55
sh -x ccc
rm -v "$SRCDIR"/lpsolve55/bin/ux*/liblpsolve55.a
cd "$SRCDIR"/lp_solve
sh -x ccc
cd "$SRCDIR"

abinfo "Installing lpsolve ..."
install -dvm755 "$PKGDIR"/usr/{bin,lib,include/lpsolve}
install -vm755 "$SRCDIR"/lp_solve/bin/ux*/lp_solve "$PKGDIR"/usr/bin/
install -vm755 "$SRCDIR"/lpsolve55/bin/ux*/liblpsolve55.so "$PKGDIR"/usr/lib/
install -vm644 "$SRCDIR"/lp*.h "$PKGDIR"/usr/include/lpsolve/
