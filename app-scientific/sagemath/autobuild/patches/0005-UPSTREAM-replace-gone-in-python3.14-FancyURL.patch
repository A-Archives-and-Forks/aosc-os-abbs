From 1f268021637a1aec8e965cfa5be3038df4aae4b6 Mon Sep 17 00:00:00 2001
From: Dima Pasechnik <dima@pasechnik.info>
Date: Thu, 25 Sep 2025 13:27:09 -0500
Subject: [PATCH 5/5] UPSTREAM: replace gone in python3.14 FancyURL

---
 build/sage_bootstrap/download/transfer.py   | 14 ++++++++------
 build/sage_bootstrap/uncompress/tar_file.py |  8 +++++---
 2 files changed, 13 insertions(+), 9 deletions(-)

diff --git a/build/sage_bootstrap/download/transfer.py b/build/sage_bootstrap/download/transfer.py
index ae139c391b1..cf719492bc3 100644
--- a/build/sage_bootstrap/download/transfer.py
+++ b/build/sage_bootstrap/download/transfer.py
@@ -20,7 +20,8 @@ import logging
 log = logging.getLogger()
 
 from sage_bootstrap.stdio import flush
-from sage_bootstrap.compat import urllib
+import urllib
+from urllib.request import build_opener, install_opener, urlretrieve
 
 
 class ProgressBar(object):
@@ -120,16 +121,17 @@ class Download(object):
             self.progress_bar.error_stop()
     
     def run(self):
-        opener = urllib.FancyURLopener()
+        opener = build_opener()
+        install_opener(opener)
+
         opener.http_error_default = self.http_error_default
         self.start_progress_bar()
         try:
             if self.progress:
-                filename, info = opener.retrieve(
-                    self.url, self.destination, self.progress_bar)
+                urlretrieve(self.url, self.destination, reporthook=self.progress_bar)
             else:
-                filename, info = opener.retrieve(
-                    self.url, self.destination)
+                urlretrieve(self.url, self.destination)
+
         except IOError as error:
             self.error_progress_bar()
             log.error(error)
diff --git a/build/sage_bootstrap/uncompress/tar_file.py b/build/sage_bootstrap/uncompress/tar_file.py
index fdfa8d240e8..62934635901 100644
--- a/build/sage_bootstrap/uncompress/tar_file.py
+++ b/build/sage_bootstrap/uncompress/tar_file.py
@@ -20,6 +20,7 @@ import tarfile
 import stat
 import subprocess
 import time
+import inspect
 
 from io import BytesIO
 
@@ -96,9 +97,10 @@ class SageBaseTarFile(tarfile.TarFile):
             members = [m if isinstance(m, tarfile.TarInfo)
                        else name_to_member[m]
                        for m in members]
-        return super(SageBaseTarFile, self).extractall(path=path,
-                                                       members=members,
-                                                       **kwargs)
+        tfile = super(SageBaseTarFile, self)
+        if 'filter' in inspect.signature(tfile.extractall).parameters:
+            kwargs['filter'] = 'fully_trusted'
+        return tfile.extractall(path=path, members=members, **kwargs)
 
     def extractbytes(self, member):
         """
