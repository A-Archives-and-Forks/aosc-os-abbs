From bba9093c30ddb8be4cf29641f35f4786be6f78d9 Mon Sep 17 00:00:00 2001
From: Jiangjin Wang <the@salted.fish>
Date: Wed, 29 Apr 2026 12:22:51 -0400
Subject: [PATCH 3/5] AOSCOS: Bypass architecture restrictions and xulrunner
 hash check

- For fetch_xulrunner:
  - Remove architecture whitelist.
  - Skip generating xulrunner hash.
- For build.sh:
  - Remove `exit 1` from fetch check_xulrunner_hash to ignore xulrunner hash
    mismatches.
  - Bypass architecture whitelist by removing `exit 1` after the check.
---
 app/build.sh                | 2 --
 app/scripts/fetch_xulrunner | 6 ------
 2 files changed, 8 deletions(-)

diff --git a/app/build.sh b/app/build.sh
index 1a05809b3..b8c68d474 100755
--- a/app/build.sh
+++ b/app/build.sh
@@ -144,7 +144,6 @@ xul_hash_file() {
 		
 		*)
 			echo "Invalid platform '$_platform'" >&2
-			exit 1
 	esac
 }
 
@@ -178,7 +177,6 @@ function check_xulrunner_hash {
 			current_xulrunner_hash=$(< "$CALLDIR/xulrunner/$platform_hash_file")
 			if [ "$current_xulrunner_hash" != "$recalculated_xulrunner_hash" ]; then
 				echo "xulrunner hashes don't match after running fetch_xulrunner!"
-				exit 1
 			fi
 		fi
 	fi
diff --git a/app/scripts/fetch_xulrunner b/app/scripts/fetch_xulrunner
index f0fa59936..0391876d7 100755
--- a/app/scripts/fetch_xulrunner
+++ b/app/scripts/fetch_xulrunner
@@ -85,10 +85,6 @@ if [[ $BUILD_WIN == 1 || $BUILD_LINUX == 1 ]]; then
 				*) echo "Invalid Windows arch: $arch" >&2; echo; usage;;
 			esac
 		fi
-		if [[ $BUILD_LINUX == 1 ]]; then
-			[[ $arch == x64 ]] && arch="x86_64"
-			case $arch in x86_64|i686|arm64) ;; *) echo "Invalid Linux arch: $arch" >&2; echo; usage;; esac
-		fi
 	fi
 fi
 
@@ -773,8 +769,6 @@ if [ $BUILD_LINUX == 1 ]; then
 		popd
 		
 		rm "firefox-$GECKO_VERSION.tar.xz"
-		
-		echo "$( $SCRIPT_DIR/xulrunner_hash -p l -a "$arch" )" > "hash-linux-${arch}"
 	done
 fi
 
-- 
