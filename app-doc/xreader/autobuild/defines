PKGNAME=xreader
PKGSEC=doc
PKGDEP="djvulibre gtk-3 libgxps poppler libsecret libspectre webkit2gtk \
        mathjax xapps"
BUILDDEP="caja gobject-introspection libxslt mate-common nemo texlive \
          yelp-tools"
PKGDES="Generic document reader"

ABTYPE=meson
MESON_AFTER=(
    '-Dcomics=true'
    '-Ddjvu=true'
    '-Ddvi=true'
    '-Dt1lib=true'
    '-Depub=true'
    '-Dpixbuf=true'
    '-Dps=true'
    '-Dtiff=true'
    '-Dxps=true'
    '-Dgtk_unix_print=true'
    '-Dkeyring=true'
    '-Dpreviewer=true'
    '-Dthumbnailer=true'
    '-Ddocs=false'
    '-Dhelp_files=true'
    '-Dintrospection=true'
    '-Denable_dbus=true'
    '-Dmathjax-directory=/usr/share/mathjax'
)
