From bd6e8226424b0dda4fb7081cb349c1d354b0ede8 Mon Sep 17 00:00:00 2001
From: Henry Chen <henry.chen@oss.cipunited.com>
Date: Sun, 31 Aug 2025 17:08:30 +0800
Subject: [PATCH] AOSCOS: wcoverartlabel: fix a qt-5 regression

... caused by debc5051ddf02c4274cfe21eba3779a14a0fc55c

fix calls to both qt-5 and qt-6 versions of QLabel::pixmap
---
 src/widget/wcoverartlabel.cpp | 10 +++++++++-
 1 file changed, 9 insertions(+), 1 deletion(-)

diff --git a/src/widget/wcoverartlabel.cpp b/src/widget/wcoverartlabel.cpp
index fa08bc5576..03d37cfc57 100644
--- a/src/widget/wcoverartlabel.cpp
+++ b/src/widget/wcoverartlabel.cpp
@@ -70,8 +70,10 @@ void WCoverArtLabel::setPixmapAndResize(const QPixmap& px) {
         m_fullSizeCover = px;
         setPixmap(m_loadedCover);
     }
-#if (QT_VERSION >= QT_VERSION_CHECK(5, 15, 0))
+#if (QT_VERSION >= QT_VERSION_CHECK(6, 6, 0))
     QSize newSize = pixmap().size() / devicePixelRatioF();
+#elif (QT_VERSION >= QT_VERSION_CHECK(5, 15, 0))
+    QSize newSize = pixmap(Qt::ReturnByValue).size() / devicePixelRatioF();
 #else
     QSize newSize = pixmap()->size() / devicePixelRatioF();
 #endif
@@ -92,7 +94,13 @@ void WCoverArtLabel::setMaxSize(const QSize newSize) {
     // Skip resizing the pixmap and label if the pixmap already fits.
     // Check if we got more space in one dimension and don't need it
     // for the other.
+#if (QT_VERSION >= QT_VERSION_CHECK(6, 6, 0))
     const QSize pixmapSize = pixmap().size() / devicePixelRatioF();
+#elif (QT_VERSION >= QT_VERSION_CHECK(5, 15, 0))
+    const QSize pixmapSize = pixmap(Qt::ReturnByValue).size() / devicePixelRatioF();
+#else
+    const QSize pixmapSize = pixmap()->size() / devicePixelRatioF();
+#endif
     if (m_pixmapSizeMax == pixmapSize ||
             (m_pixmapSizeMax.height() == pixmapSize.height() &&
                     m_pixmapSizeMax.width() > pixmapSize.width()) ||
-- 
2.51.0

