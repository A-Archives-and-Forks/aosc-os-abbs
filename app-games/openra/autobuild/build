abinfo "Setting OpenRA version ..."
make version

abinfo "Building OpenRA ..."
make all \
    RUNTIME=mono \
    TARGETPLATFORM=unix-generic

abinfo "Installing OpenRA self ..."
make install \
    RUNTIME=mono \
    TARGETPLATFORM=unix-generic \
    DESTDIR="$PKGDIR" \
    prefix=/usr

abinfo "Installing OpenRA data ..."
make install-linux-appdata \
    DESTDIR="$PKGDIR" \
    prefix=/usr

abinfo "Installing OpenRA AppData XML ..."
make install-linux-shortcuts \
    DESTDIR="$PKGDIR" \
    prefix=/usr
