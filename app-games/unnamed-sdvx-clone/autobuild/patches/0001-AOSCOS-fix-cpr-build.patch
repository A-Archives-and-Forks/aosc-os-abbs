From bc9bd7be9df0cd8f4110dd485610f070ea910cfc Mon Sep 17 00:00:00 2001
From: Henry Chen <henry.chen@oss.cipunited.com>
Date: Mon, 1 Sep 2025 02:19:53 +0800
Subject: [PATCH 1/5] AOSCOS: fix cpr build

- remove Werror for deprecated curl functions
- add cstdint for gcc 15 compatibility
---
 third_party/cpr/CMakeLists.txt         | 2 +-
 third_party/cpr/include/cpr/callback.h | 1 +
 2 files changed, 2 insertions(+), 1 deletion(-)

diff --git a/third_party/cpr/CMakeLists.txt b/third_party/cpr/CMakeLists.txt
index 9bd47ff..49fe646 100644
--- a/third_party/cpr/CMakeLists.txt
+++ b/third_party/cpr/CMakeLists.txt
@@ -57,7 +57,7 @@ endif()
 
 if ("${CMAKE_CXX_COMPILER_ID}" STREQUAL "MSVC")
 else()
-    set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -Wall -Wextra -Wpedantic -Werror")
+    set(CMAKE_CXX_FLAGS "${CMAKE_CXX_FLAGS} -Wall -Wextra -Wpedantic")
 endif()
 
 # SSL
diff --git a/third_party/cpr/include/cpr/callback.h b/third_party/cpr/include/cpr/callback.h
index b90c1bb..01bf39f 100644
--- a/third_party/cpr/include/cpr/callback.h
+++ b/third_party/cpr/include/cpr/callback.h
@@ -5,6 +5,7 @@
 
 #include <functional>
 #include <utility>
+#include <cstdint>
 
 namespace cpr {
 
-- 
2.52.0

