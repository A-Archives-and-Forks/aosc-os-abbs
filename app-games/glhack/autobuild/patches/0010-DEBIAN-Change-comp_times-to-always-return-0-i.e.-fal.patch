From 680d50c5d484dd2507947111431c0ff1be242ff5 Mon Sep 17 00:00:00 2001
From: Santiago Vila <sanvila@debian.org>
Date: Sat, 4 Apr 2026 21:10:44 +0800
Subject: [PATCH 10/12] DEBIAN: Change comp_times() to always return 0 (i.e.
 false) since BUILD_TIME is not defined anymore

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 src/version.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/version.c b/src/version.c
index b35475c..ebb1a33 100644
--- a/src/version.c
+++ b/src/version.c
@@ -60,7 +60,7 @@ boolean
 comp_times(filetime)
 long filetime;
 {
-	return((boolean)(filetime < BUILD_TIME));
+	return((boolean)(0));
 }
 #endif
 
