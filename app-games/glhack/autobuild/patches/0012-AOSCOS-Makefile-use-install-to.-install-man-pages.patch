From 554ca6ed5bd447b525e645338d8c36bfed948914 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Sat, 4 Apr 2026 21:38:50 +0800
Subject: [PATCH 12/12] AOSCOS: Makefile: use install to... install man pages

Lest they become files when they were installed.

Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 Makefile | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/Makefile b/Makefile
index fea11f8..5a55595 100644
--- a/Makefile
+++ b/Makefile
@@ -106,8 +106,8 @@ Guidebook:
 	( cd doc ; $(MAKE) Guidebook )
 
 manpages:
-	cp doc/glhack.6 $(MANDIR)/man6
-	cp doc/glhackrc.5 $(MANDIR)/man5
+	install -Dvm644 doc/glhack.6 $(MANDIR)/man6/glhack.6
+	install -Dvm644 doc/glhackrc.5 $(MANDIR)/man5/glhackrc.5
 	# cp doc/nethack-guidebook.6 $(MANDIR)/man6
 	( cd doc ; $(MAKE) manpages )
 
-- 
2.52.0

