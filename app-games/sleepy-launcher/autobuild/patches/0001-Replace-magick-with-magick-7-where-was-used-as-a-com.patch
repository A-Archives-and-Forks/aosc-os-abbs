From 525a041d76de2e08d8288b2b1d639635ac08b3a5 Mon Sep 17 00:00:00 2001
From: Mikura Kyouka <13207280@qq.com>
Date: Tue, 2 Dec 2025 18:33:36 +0800
Subject: [PATCH] Replace `magick` with `magick-7` where was used as a command
 to test if it was installed

---
 src/background.rs                | 2 +-
 src/ui/first_run/dependencies.rs | 2 +-
 src/ui/first_run/welcome.rs      | 2 +-
 3 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/src/background.rs b/src/background.rs
index fdfd795..c986643 100644
--- a/src/background.rs
+++ b/src/background.rs
@@ -144,7 +144,7 @@ pub fn download_background() -> anyhow::Result<()> {
     }
 
     if regenerate_image {
-        Command::new("magick")
+        Command::new("magick-7")
             .arg(crate::BACKGROUND_FILE.as_path())
             .arg(crate::BACKGROUND_OVERLAY_FILE.as_path())
             .args(["-layers", "flatten"])
diff --git a/src/ui/first_run/dependencies.rs b/src/ui/first_run/dependencies.rs
index c7c2427..fd880aa 100644
--- a/src/ui/first_run/dependencies.rs
+++ b/src/ui/first_run/dependencies.rs
@@ -191,7 +191,7 @@ impl SimpleAsyncComponent for DependenciesApp {
         match msg {
             #[allow(unused_must_use)]
             DependenciesAppMsg::Continue => {
-                let packages = ["git", "magick"];
+                let packages = ["git", "magick-7"];
 
                 for package in packages {
                     if !is_available(package) {
diff --git a/src/ui/first_run/welcome.rs b/src/ui/first_run/welcome.rs
index 44d0013..febfe92 100644
--- a/src/ui/first_run/welcome.rs
+++ b/src/ui/first_run/welcome.rs
@@ -81,7 +81,7 @@ impl SimpleAsyncComponent for WelcomeApp {
             WelcomeAppMsg::Continue => {
                 let installed =
                     is_available("git") &&
-                    is_available("magick") &&
+                    is_available("magick-7") &&
                     (is_available("7z") || is_available("7za"));
 
                 if installed {
