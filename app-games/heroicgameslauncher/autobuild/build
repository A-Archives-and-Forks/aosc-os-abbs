if ab_match_arch loongarch64; then
    abinfo "Overriding Electron mirror for loongarch64 ..."
    export ELECTRON_MIRROR="https://github.com/darkyzhou/electron-loong64/releases/download/"
    export electron_use_remote_checksums=1
elif ab_match_arch riscv64; then
    abinfo "Overriding Electron mirror for riscv64 ..."
    export ELECTRON_MIRROR="https://github.com/riscv-forks/electron-riscv-releases/releases/download/"
    export electron_use_remote_checksums=1
fi

abinfo "Installing NPM dependencies ..."
pnpm install

abinfo "Downloading helper binaries ..."
pnpm download-helper-binaries

abinfo "Building ..."
pnpm electron-vite build
pnpm electron-builder --dir

abinfo "Installing Heroic Games Launcher ..."
install -dvm755 "$PKGDIR"/usr/lib/heroic-games-launcher
cp -rv "$SRCDIR"/dist/linux*-unpacked/* "$PKGDIR"/usr/lib/heroic-games-launcher/

abinfo "Creating symbolic link ..."
mkdir -pv "$PKGDIR"/usr/bin
ln -sv ../lib/heroic-games-launcher/heroic "$PKGDIR"/usr/bin/heroic

abinfo "Installing application icon ..."
install -Dvm644 "$SRCDIR"/public/icon.png \
		"$PKGDIR"/usr/share/pixmaps/heroic.png
