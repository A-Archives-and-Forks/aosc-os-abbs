From 8458dd0ed64352db47897a00f65fc2a05bd730c2 Mon Sep 17 00:00:00 2001
From: Ruikai Liu <rickliu2000@outlook.com>
Date: Mon, 10 Nov 2025 16:59:48 +0800
Subject: [PATCH] UPSTREAM: qt6: use new way to access the native
 display/window on X11/Wayland

Links: https://github.com/melonDS-emu/melonDS/commit/89e70dfba77c9042e8d6c3cdd5873497ac24ec1e
       https://github.com/melonDS-emu/melonDS/commit/420a1fa7e75121d5f9de2a886b5c2742563d9a3d
---
 src/frontend/qt_sdl/Screen.cpp | 35 +++++++++++++++++++++++++++-------
 src/frontend/qt_sdl/Window.cpp |  3 ---
 src/frontend/qt_sdl/main.cpp   |  3 ---
 3 files changed, 28 insertions(+), 13 deletions(-)

diff --git a/src/frontend/qt_sdl/Screen.cpp b/src/frontend/qt_sdl/Screen.cpp
index 17fd4b86..6d58fff9 100755
--- a/src/frontend/qt_sdl/Screen.cpp
+++ b/src/frontend/qt_sdl/Screen.cpp
@@ -23,11 +23,7 @@
 
 #include <QPaintEvent>
 #include <QPainter>
-#ifndef _WIN32
-#ifndef APPLE
-#include <qpa/qplatformnativeinterface.h>
-#endif
-#endif
+
 #include <QDateTime>
 
 #include "OpenGLSupport.h"
@@ -50,6 +46,14 @@
 
 using namespace melonDS;
 
+#if !defined(_WIN32) && !defined(APPLE)
+#if QT_VERSION >= QT_VERSION_CHECK(6, 5, 0)
+using namespace QNativeInterface;
+#else
+#include <qpa/qplatformnativeinterface.h>
+#endif
+#endif
+
 
 const u32 kOSDMargin = 6;
 const int kLogoWidth = 192;
@@ -1285,8 +1289,25 @@ std::optional<WindowInfo> ScreenPanelGL::getWindowInfo()
     wi.type = WindowInfo::Type::MacOS;
     wi.window_handle = reinterpret_cast<void*>(winId());
     #else
-    QPlatformNativeInterface* pni = QGuiApplication::platformNativeInterface();
     const QString platform_name = QGuiApplication::platformName();
+
+    #if QT_VERSION >= QT_VERSION_CHECK(6, 5, 0)
+    if (platform_name == QStringLiteral("xcb"))
+    {
+        wi.type = WindowInfo::Type::X11;
+        const QX11Application* x11 = qApp->nativeInterface<QX11Application>();
+        wi.display_connection = x11->display();
+        wi.window_handle = reinterpret_cast<void*>(winId());
+    }
+    else if (platform_name == QStringLiteral("wayland"))
+    {
+        wi.type = WindowInfo::Type::Wayland;
+        const QWaylandApplication* wl = qApp->nativeInterface<QWaylandApplication>();
+        wi.display_connection = wl->display();
+        wi.window_handle = reinterpret_cast<void*>(winId());
+    }
+    #else
+    QPlatformNativeInterface* pni = QGuiApplication::platformNativeInterface();
     if (platform_name == QStringLiteral("xcb"))
     {
         wi.type = WindowInfo::Type::X11;
@@ -1303,9 +1324,9 @@ std::optional<WindowInfo> ScreenPanelGL::getWindowInfo()
         wi.display_connection = pni->nativeResourceForWindow("display", handle);
         wi.window_handle = pni->nativeResourceForWindow("surface", handle);
     }
+    #endif
     else
     {
-        //qCritical() << "Unknown PNI platform " << platform_name;
         Platform::Log(Platform::LogLevel::Error, "Unknown PNI platform %s\n", platform_name.toStdString().c_str());
         return std::nullopt;
     }
diff --git a/src/frontend/qt_sdl/Window.cpp b/src/frontend/qt_sdl/Window.cpp
index b5a9b690..9b3ab95c 100755
--- a/src/frontend/qt_sdl/Window.cpp
+++ b/src/frontend/qt_sdl/Window.cpp
@@ -47,9 +47,6 @@
 #include <unistd.h>
 #include <sys/socket.h>
 #include <signal.h>
-#ifndef APPLE
-#include <qpa/qplatformnativeinterface.h>
-#endif
 #endif
 
 #include "main.h"
diff --git a/src/frontend/qt_sdl/main.cpp b/src/frontend/qt_sdl/main.cpp
index 65142663..bcb20961 100644
--- a/src/frontend/qt_sdl/main.cpp
+++ b/src/frontend/qt_sdl/main.cpp
@@ -42,9 +42,6 @@
 #include <unistd.h>
 #include <sys/socket.h>
 #include <signal.h>
-#ifndef APPLE
-#include <qpa/qplatformnativeinterface.h>
-#endif
 #endif
 
 #include <SDL2/SDL.h>
-- 
