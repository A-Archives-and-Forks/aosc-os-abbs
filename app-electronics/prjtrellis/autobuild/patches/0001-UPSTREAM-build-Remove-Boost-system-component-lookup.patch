From e821bcbecdc997d71766836a200e16b27535a835 Mon Sep 17 00:00:00 2001
From: Aki Van Ness <aki@lethalbit.net>
Date: Tue, 21 Oct 2025 10:21:55 -0700
Subject: [PATCH] build: Remove Boost `system` component lookup

The `system` component of the Boost libraries has been
properly removed from 1.89.0, so we don't need to actually
do the lookup to see if it is present.

Also, as far as I can tell, nothing actually uses that component
directly anyway, so we can just gut it.
---
 CMakeLists.txt | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index b4f02c71..dbfddc30 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -46,7 +46,7 @@ if (WASI)
     endif()
 endif()
 
-set(boost_libs filesystem program_options system)
+set(boost_libs filesystem program_options)
 if (Threads_FOUND)
     list(APPEND boost_libs thread)
 else()
@@ -63,6 +63,7 @@ endif()
 
 find_package(Boost REQUIRED COMPONENTS ${boost_libs})
 
+
 find_package(Git)
 
 if (NOT DEFINED PYBIND11_INCLUDE_DIR)

