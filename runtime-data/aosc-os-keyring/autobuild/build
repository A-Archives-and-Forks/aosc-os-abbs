abinfo "Installing keys ..."
install -Dvm644 "$SRCDIR"/aosc-os-2024-10-06-ed25519-F54DE04F93DFEDBA123FC2933AE2C2BE062E9F06.gpg \
    "$PKGDIR"/usr/share/keyrings/aosc-archive-keyring.gpg

