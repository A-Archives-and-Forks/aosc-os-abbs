PKGNAME=totem-pl-parser
PKGSEC=gnome
PKGDEP="libarchive libgcrypt uchardet"
BUILDDEP="gobject-introspection"
PKGDES="Totem playlist parser library"

ABTYPE=meson
MESON_AFTER=(
    '-Denable-libarchive=yes'
    '-Denable-libgcrypt=yes'
    '-Denable-uchardet=yes'
    '-Denable-gtk-doc=false'
    '-Dintrospection=true'
)
