PKGNAME=libchamplain
PKGSEC=gnome
PKGDEP="clutter-gtk gtk-3 libsoup-3"
BUILDDEP="gobject-introspection vala"
PKGDES="GTK widget for displaying rasterized maps"

ABTYPE=meson
# Note: -Dmemphis=false, memphis (https://github.com/jiuka/memphis) is dead.
MESON_AFTER=(
    '-Dmemphis=false'
    '-Dintrospection=true'
    '-Dvapi=true'
    '-Dwidgetry=true'
    '-Dgtk_doc=false'
    '-Ddemos=false'
    '-Dlibsoup3=true'
)
