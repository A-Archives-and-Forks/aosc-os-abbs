PKGNAME=ghex
PKGSEC=gnome
PKGDEP="gtk-4 libadwaita"
BUILDDEP="gobject-introspection vala"
PKGDES="Bin/Hex editor for GNOME"

ABTYPE=meson
MESON_AFTER=(
    '-Ddevelopment=false'
    '-Dmmap-buffer-backend=true'
    '-Ddirect-buffer-backend=true'
    '-Dintrospection=enabled'
    '-Dgtk_doc=false'
    '-Dstatic-html-help=false'
    '-Dvapi=true'
)
