PKGNAME=gnome-settings-daemon
PKGSEC=gnome
PKGDEP="alsa-lib colord cups gcr-4 geoclue2 geocode-glib gnome-desktop \
        libcanberra libgweather networkmanager systemd xwayland"
PKGDES="Manages GNOME session and applications parameters"

MESON_AFTER=(
    '-Dsystemd=true'
    '-Delogind=false'
    '-Dalsa=true'
    '-Dgudev=true'
    '-Dcups=true'
    '-Dnetwork_manager=true'
    '-Drfkill=true'
    '-Dsmartcard=true'
    '-Dusb-protection=true'
    '-Dx11=true'
    '-Dxwayland=true'
    '-Dwwan=true'
    '-Dgcr3=false'
    '-Dcolord=true'
)
