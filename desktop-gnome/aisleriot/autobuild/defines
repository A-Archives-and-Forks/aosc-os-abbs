PKGNAME=aisleriot
PKGSEC=gnome
PKGDEP="gtk-3 guile libcanberra librsvg"
BUILDDEP="itstool"
PKGDES="Solitaire card game for GNOME"

ABTYPE=meson
MESON_AFTER=(
    '-Dbinreloc=false'
    '-Ddbg=false'
    '-Ddbgui=false'
    '-Ddefault_theme_format=svg-rsvg'
    '-Ddefault_theme=gnomangelo_bitmap.svgz'
    '-Ddocs=true'
    '-Dgconf=false'
    '-Dhelp_format=html'
    '-Dhelp_method=ghelp'
    '-Dsound=true'
    '-Dtheme_fixed=true'
    '-Dtheme_kde=false'
    '-Dtheme_pysol=true'
    '-Dtheme_pysol_path=/usr/share/PySolFC'
    '-Dtheme_svg_qtsvg=false'
    '-Dtheme_svg_rsvg=true'
)
