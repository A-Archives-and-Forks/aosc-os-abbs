PKGNAME=epiphany
PKGSEC=gnome
PKGDEP="at-spi2-core dconf desktop-file-utils gcr gnome-desktop \
        gsettings-desktop-schemas iso-codes \
        json-glib libnotify libsecret libsoup libwnck-3 nettle nss \
        webkit2gtk libdazzle libhandy libportal"
BUILDDEP="appstream-glib docbook-xml gobject-introspection gtk-doc \
          intltool itstool startup-notification"
PKGDES="Web browser based on the WebKit rendering engine"

MESON_AFTER=(
    '-Ddeveloper_mode=false'
    '-Dlibportal=enabled'
    '-Dnetwork_tests=disabled'
    '-Dtech_preview=false'
    '-Dsoup2=enabled'
)
