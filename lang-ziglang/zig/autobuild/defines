PKGNAME=zig
PKGSEC=devel
PKGDEP="llvm-20 zlib zstd"
PKGDES="General-purpose programming language and toolchain for maintaining robust, optimal, and reusable software"

ABTYPE=cmakeninja
USECLANG=1
CMAKE_AFTER=(
    -DZIG_VERSION="${PKGVER}"
    -DZIG_STATIC=OFF
    -DZIG_SHARED_LLVM=ON
    -DZIG_USE_LLVM_CONFIG=ON
    -DZIG_TARGET_MCPU=baseline
    -DZIG_EXTRA_BUILD_ARGS="--build-id=sha1"
)

# FIXME: loongson3: Deadlock during stage2 to stage3
FAIL_ARCH="!(amd64|arm64|riscv64|loongarch64|loongarch64_nosimd|ppc64el)"
