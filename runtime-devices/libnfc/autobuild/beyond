abinfo "Installing udev rule ..."
install -Dvm644 "$SRCDIR"/contrib/udev/93-pn53x.rules \
    -t "$PKGDIR"/usr/lib/udev/rules.d/

abinfo "Installing module blacklist file ..."
install -Dvm644 "$SRCDIR"/contrib/linux/blacklist-libnfc.conf \
    -t "$PKGDIR"/usr/lib/modprobe.d/

abinfo "Installing sample file ..."
install -Dvm644 "$SRCDIR"/libnfc.conf.sample \
    "$PKGDIR"/etc/nfc/libnfc.conf
mkdir -pv "$PKGDIR"/etc/nfc/devices.d
