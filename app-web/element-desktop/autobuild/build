abinfo "Installing Element Web dependencies ..."
cd "$SRCDIR"/apps/web
pnpm install

abinfo "Building Element Web ..."
VERSION="$PKGVER" pnpm build
cp -v "$SRCDIR"/apps/web/config.sample.json \
    "$SRCDIR"/apps/web/webapp/

abinfo "Installing Element Desktop dependencies ..."
cd "$SRCDIR"/apps/desktop
pnpm install

abinfo "Building Element Desktop ..."

abinfo "Building native module ..."
pnpm run build:native

abinfo "Building app ..."
if ab_match_arch arm64; then
    pnpm run build --arm64
elif ab_match_arch amd64; then
    pnpm run build
fi

abinfo "Installing Element Desktop ..."
install -dvm755 "$PKGDIR"/usr/lib/element
cp -rv "$SRCDIR"/apps/desktop/dist/*-unpacked/* \
    "$PKGDIR"/usr/lib/element/

abinfo "Installing Element Web to Element Desktop ..."
cp -rv "$SRCDIR"/apps/web/webapp \
    "$PKGDIR"/usr/lib/element/resources/

abinfo "Installing default Element config ..."
install -Dvm644 "$SRCDIR"/apps/desktop/element.io/release/config.json \
    -t "$PKGDIR"/usr/lib/element/resources/webapp/

abinfo "Creating symbolic link ..."
install -dvm755 "$PKGDIR"/usr/bin
ln -sv ../lib/element/element-desktop "$PKGDIR"/usr/bin/element-desktop

abinfo "Installing application icon ..."
install -Dvm644 "$SRCDIR"/apps/desktop/build/icon.png \
    "$PKGDIR"/usr/share/pixmaps/element.png
