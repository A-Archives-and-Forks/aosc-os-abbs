From 4af244ee283847ed21fd5577761adbaaa2d9fae4 Mon Sep 17 00:00:00 2001
From: "Rong \"Mantle\" Bao" <webmaster@csmantle.top>
Date: Fri, 16 Jan 2026 08:08:21 +0800
Subject: [PATCH 5/5] AOSCOS: Disable JSPI on MIPS64 to work around Bug 2010439

This bug is fixed in >= 148.0, so this patch is expected to be dropped
in the next major release.

Link: https://bugzilla.mozilla.org/show_bug.cgi?id=2010439
---
 js/moz.configure | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/js/moz.configure b/js/moz.configure
index 765c1de95f38..d318bd439e2d 100644
--- a/js/moz.configure
+++ b/js/moz.configure
@@ -718,7 +718,8 @@ def default_wasm_jspi(
         "aarch64",
         "arm",
         "loongarch64",
-        "mips64",
+# AOSCOS: Disable JSPI for Fx147 to work around Bug 2010439.
+#       "mips64",
         "riscv64",
     ):
         return True
