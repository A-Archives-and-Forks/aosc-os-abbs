From 8b68e1df65d4d24794c293a88e47912292b8061b Mon Sep 17 00:00:00 2001
From: Henry Chen <henry.chen@oss.cipunited.com>
Date: Wed, 13 Aug 2025 19:32:29 +0800
Subject: [PATCH 4/5] AOSCOS: rust/allocator-api2: remove an autoref warning

This warning only exists when building with rustc >= 1.89.0.
---
 third_party/rust/allocator-api2/src/stable/vec/mod.rs | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/third_party/rust/allocator-api2/src/stable/vec/mod.rs b/third_party/rust/allocator-api2/src/stable/vec/mod.rs
index 446f50087b..a4cda8e9f7 100644
--- a/third_party/rust/allocator-api2/src/stable/vec/mod.rs
+++ b/third_party/rust/allocator-api2/src/stable/vec/mod.rs
@@ -1899,7 +1899,7 @@ impl<T, A: Allocator> Vec<T, A> {
     #[cfg(not(no_global_oom_handling))]
     #[inline(always)]
     unsafe fn append_elements(&mut self, other: *const [T]) {
-        let count = unsafe { (*other).len() };
+        let count = unsafe { (&(*other)).len() };
         self.reserve(count);
         let len = self.len();
         unsafe { ptr::copy_nonoverlapping(other as *const T, self.as_mut_ptr().add(len), count) };
-- 
2.50.1

