abinfo "Installing Vim syntax highlighting and editor configurations ..."
install -Dvm644 "$SRCDIR"/contrib/vim/ftdetect/angie.vim \
    "$PKGDIR"/usr/share/vim/vimfiles/ftdetect/angie.vim
install -Dvm644 "$SRCDIR"/contrib/vim/syntax/angie.vim \
    "$PKGDIR"/usr/share/vim/vimfiles/syntax/angie.vim
install -Dvm644 "$SRCDIR"/contrib/vim/indent/angie.vim \
    "$PKGDIR"/usr/share/vim/vimfiles/indent/angie.vim

abinfo "Dropping .default templates ..."
rm -v "$PKGDIR"/etc/angie/*.default

abinfo "Installing documentation ..."
install -dv "$PKGDIR"/usr/share/angie
cp -av "$PKGDIR"/etc/angie/html/ \
    "$PKGDIR"/usr/share/angie
rm -rv "$PKGDIR"/etc/angie/html/

abinfo "Installing man page ..."
install -Dvm644 "$SRCDIR"/man/angie.8 \
    "$PKGDIR"/usr/share/man/man8/angie.8
