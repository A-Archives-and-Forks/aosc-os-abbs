PKGNAME=dovecot
PKGSEC=net
PKGDEP="bzip2 curl clucene expat krb5 linux-pam lz4 mariadb openldap \
        openssl postgresql sqlite xz libnsl2"
PKGDES="IMAP and POP3 email server"

AUTOTOOLS_AFTER=(
    '--libexecdir=/usr/lib'
    '--with-moduledir=/usr/lib/dovecot/modules'
    '--with-pam'
    '--with-mysql'
    '--with-pgsql'
    '--with-sqlite'
    '--with-ssldir=/etc/ssl'
    '--with-gssapi'
    '--with-ldap=plugin'
    '--with-bzlib'
    '--with-lz4'
    '--with-libcap'
    '--with-solr'
)
