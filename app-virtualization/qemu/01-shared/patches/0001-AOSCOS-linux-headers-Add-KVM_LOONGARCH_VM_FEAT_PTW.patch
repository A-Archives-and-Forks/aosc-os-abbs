From 8f0ab4ae7d0e0631af74111303fca96add475fb0 Mon Sep 17 00:00:00 2001
From: Xi Ruoyao <xry111@xry111.site>
Date: Thu, 27 Nov 2025 23:36:00 +0800
Subject: [PATCH 1/3] AOSCOS: linux-headers: Add KVM_LOONGARCH_VM_FEAT_PTW

It's needed to backport the upstream commit to resolve the severe
stability issue on 3C6000.

For simplicity, only add this macro instead of backport the update of
the entire vendored Linux header copy.

Link: https://gitlab.com/qemu-project/qemu/-/commit/2e0096a2b6a5
Signed-off-by: Xi Ruoyao <xry111@xry111.site>
---
 linux-headers/asm-loongarch/kvm.h | 1 +
 1 file changed, 1 insertion(+)

diff --git a/linux-headers/asm-loongarch/kvm.h b/linux-headers/asm-loongarch/kvm.h
index 5f354f5c68..57ba1a563b 100644
--- a/linux-headers/asm-loongarch/kvm.h
+++ b/linux-headers/asm-loongarch/kvm.h
@@ -103,6 +103,7 @@ struct kvm_fpu {
 #define  KVM_LOONGARCH_VM_FEAT_PMU		5
 #define  KVM_LOONGARCH_VM_FEAT_PV_IPI		6
 #define  KVM_LOONGARCH_VM_FEAT_PV_STEALTIME	7
+#define  KVM_LOONGARCH_VM_FEAT_PTW		8
 
 /* Device Control API on vcpu fd */
 #define KVM_LOONGARCH_VCPU_CPUCFG	0
-- 
2.52.0

