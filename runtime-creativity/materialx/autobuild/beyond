abinfo "Deleting stray files installed by the project..."
for i in python; do
    rm -rv "${PKGDIR}/usr/${i}"
done

abinfo "Moving documentation to the correct location ..."
mkdir -pv "$PKGDIR"/usr/share/doc/materialx
mv -v \
    "$PKGDIR"/usr/share/doc/README.md \
    "$PKGDIR"/usr/share/doc/CHANGELOG.md \
    "$PKGDIR"/usr/share/doc/LICENSE \
    "$PKGDIR"/usr/share/doc/THIRD-PARTY.md \
    -t "$PKGDIR"/usr/share/doc/materialx/

abinfo "Deduplicating materialx standard libraries in python package"
rm -rv "${PKGDIR}/usr/lib/python${ABPY3VER}/site-packages/MaterialX/share"
for i in resources library; do
    ln -sv ../../../../share/materialx/$i \
        "${PKGDIR}/usr/lib/python${ABPY3VER}/site-packages/MaterialX/$i"
done
