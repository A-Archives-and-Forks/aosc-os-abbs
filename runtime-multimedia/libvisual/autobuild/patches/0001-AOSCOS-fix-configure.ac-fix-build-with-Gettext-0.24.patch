From 0582c6973c055c4939a8e74c2ea871a2650fb648 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 14 May 2025 23:00:37 +0800
Subject: [PATCH 1/2] AOSCOS: fix(configure.ac): fix build with Gettext >= 0.24

According to upstream bug report, to quote Bruno Haible:

  This error indicates that you are using a po/Makefile.in.in from gettext
  0.23.1 or older together with a gettext.m4 macro from 0.24. This is not
  supported.

  The 'autopoint' program is designed to avoid this mistaken situation.
  See its documentation:
  https://www.gnu.org/software/gettext/manual/html_node/autopoint-Invocation.html

Link: https://savannah.gnu.org/bugs/?66968
Signed-off-by: Mingcong Bai <jeffbai@aosc.io>
---
 autogen.sh | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/autogen.sh b/autogen.sh
index a547c666..7d6e0139 100755
--- a/autogen.sh
+++ b/autogen.sh
@@ -4,8 +4,10 @@
 
 set -e -u
 
-autoreconf --install --verbose --force || \
-autoreconf --install --verbose --force
+# NOTE: We're running things twice to workaround bug "too many loops" in aclocal
+autopoint -f
+AUTOPOINT=true autoreconf --install --verbose --force || \
+AUTOPOINT=true autoreconf --install --verbose --force
 
 if [[ -z "${NOCONFIGURE:-}" ]]; then
     if [[ "$#" == 0 ]]; then
-- 
2.49.0

