PKGNAME=libportal
PKGSEC=libs
PKGDEP="glibc glib"
BUILDDEP="gobject-introspection gtk-3 gtk-4 qt-5 qt-6 vala"
PKGDES="Library for GIO-style async APIs for Flatpak portals"

ABTYPE=meson
MESON_AFTER=(
    '-Dbackend-gtk3=enabled'
    '-Dbackend-gtk4=enabled'
    '-Dbackend-qt5=enabled'
    '-Dbackend-qt6=enabled'
    '-Dportal-tests=false'
    '-Dintrospection=true'
    '-Dvapi=true'
    '-Ddocs=false'
    '-Dtests=false'
)
