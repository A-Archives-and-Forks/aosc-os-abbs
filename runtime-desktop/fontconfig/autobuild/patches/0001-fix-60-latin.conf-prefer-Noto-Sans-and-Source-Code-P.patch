From 28b7e0384d3169201810582e4cbc3bb55b4a0044 Mon Sep 17 00:00:00 2001
From: Mingcong Bai <jeffbai@aosc.io>
Date: Wed, 22 May 2024 23:14:08 +0800
Subject: [PATCH 1/2] fix(60-latin.conf): prefer Noto Sans and Source Code Pro
 for Latin UI

---
 conf.d/60-latin.conf | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/conf.d/60-latin.conf b/conf.d/60-latin.conf
index ae3be3c7..8513bf2d 100644
--- a/conf.d/60-latin.conf
+++ b/conf.d/60-latin.conf
@@ -35,6 +35,7 @@
 	<alias>
 		<family>monospace</family>
 		<prefer>
+			<family>Source Code Pro</family>
 			<family>Noto Sans Mono</family>
 			<family>DejaVu Sans Mono</family>
 			<family>Inconsolata</family>
@@ -77,9 +78,9 @@
 	<alias>
 		<family>system-ui</family>
 		<prefer>
+			<family>Noto Sans UI</family>
 			<family>Adwaita Sans</family>
 			<family>Cantarell</family>
-			<family>Noto Sans UI</family>
 			<family>Segoe UI</family>
 			<family>Segoe UI Historic</family>
 			<family>Segoe UI Symbol</family>
-- 
2.52.0

